<%- include('../layouts/main') %>

<div class="container" style="max-width: 620px;">
  <div class="form-card" style="max-width: 100%; border-top: 4px solid var(--accent);">
    <h2 style="text-align: center; margin-bottom: 0.5rem; font-family: var(--font-display);">Register as a Seller</h2>
    <p style="text-align: center; color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;">Create your store and start listing items today.</p>

    <!-- Seller pending notice -->
    <div class="approval-banner pending" style="margin-bottom:1.5rem; display: flex; gap: 12px; background: #fffbeb; border: 1px solid #fef3c7; border-radius: var(--radius-md); padding: 1rem;">
      <span class="approval-banner-icon" style="color: #b45309; font-size: 1.25rem;"><i class="fa-solid fa-clock"></i></span>
      <div>
        <strong style="color: #b45309; font-size: 0.9rem;">Seller accounts require admin approval.</strong><br>
        <span style="font-size:0.8rem; color: var(--text-secondary);">After signing up, wait for an approval email before you can log in to the Seller Portal.</span>
      </div>
    </div>

    <form action="/auth/signup" method="POST" enctype="multipart/form-data" id="sellerSignupForm">
      <input type="hidden" name="role" value="seller">

      <!-- Basic Info -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group" style="grid-column: 1/-1;">
          <label for="name"><i class="fa-solid fa-user"></i> Full Name</label>
          <input type="text" name="name" id="name" class="form-control" placeholder="John Doe" required>
        </div>

        <div class="form-group">
          <label for="email"><i class="fa-solid fa-envelope"></i> Email Address</label>
          <input type="email" name="email" id="email" class="form-control" placeholder="name@example.com" required>
        </div>

        <div class="form-group">
          <label for="phone"><i class="fa-solid fa-phone"></i> Phone Number</label>
          <input type="tel" name="phone" id="phone" class="form-control" placeholder="+919876543210" required>
        </div>

        <div class="form-group">
          <label for="password"><i class="fa-solid fa-lock"></i> Password</label>
          <input type="password" name="password" id="password" class="form-control" placeholder="Min. 8 characters" minlength="8" required>
        </div>

        <div class="form-group">
          <label for="address"><i class="fa-solid fa-location-dot"></i> Personal Address</label>
          <input type="text" name="address" id="address" class="form-control" placeholder="Flat 4B, Andheri West, Mumbai 400053" required>
        </div>
      </div>

      <!-- Seller Business Info -->
      <div style="border-top: 1px solid var(--border); padding-top: 1.25rem; margin-top: 1rem;">
        <p style="font-weight:600; font-size:0.9rem; margin-bottom:1rem; color: var(--text-secondary);">
          <i class="fa-solid fa-store"></i> Seller Business Info
        </p>
        <div class="form-group">
          <label for="businessName">Business / Shop Name</label>
          <input type="text" name="businessName" id="businessName" class="form-control" placeholder="My Rental Store" required>
        </div>
        <div class="form-group">
          <label for="businessAddress">Business Address</label>
          <input type="text" name="businessAddress" id="businessAddress" class="form-control" placeholder="Shop 12, Market Road, Pune" required>
        </div>
      </div>

      <!-- Aadhaar Section -->
      <div style="border-top: 1px solid var(--border); padding-top: 1.25rem; margin-top: 1rem;">
        <p style="font-weight:600; font-size:0.9rem; margin-bottom:1rem; color: var(--text-secondary);">
          <i class="fa-solid fa-id-card"></i> Aadhaar Verification (Required for verification)
        </p>

        <div class="form-group">
          <label for="aadhaarNumber">Aadhaar Number</label>
          <input type="text" name="aadhaarNumber" id="aadhaarNumber" class="form-control"
            placeholder="XXXX XXXX XXXX" maxlength="14" required
            oninput="formatAadhaar(this)">
          <span class="form-hint">12-digit Aadhaar number for store verification.</span>
        </div>

        <div class="form-group">
          <label>Aadhaar Card Photo</label>
          <div class="file-upload-area" onclick="document.getElementById('aadhaarDoc').click()" style="border: 2px dashed var(--border); border-radius: var(--radius-md); padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s;">
            <input type="file" name="aadhaarDoc" id="aadhaarDoc" accept="image/*,application/pdf" style="display: none;" required
              onchange="showFileName(this, 'aadhaarFileName')">
            <div class="file-upload-icon" style="font-size: 2rem; color: var(--text-hint); margin-bottom: 0.5rem;"><i class="fa-solid fa-id-card"></i></div>
            <div class="file-upload-text" id="aadhaarFileName" style="font-size: 0.85rem; color: var(--text-secondary);">
              Click to upload Aadhaar card image or PDF<br>
              <small style="color:var(--text-hint);">Supports JPG, PNG, PDF — max 5MB</small>
            </div>
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-accent" style="width: 100%; margin-top: 1.5rem; padding: 0.85rem;">
        <i class="fa-solid fa-user-plus"></i> Create Seller Account
      </button>
    </form>

    <p style="text-align: center; margin-top: 1.5rem; color: var(--text-secondary); font-size: 0.9rem;">
      Already registered as a Seller? <a href="/auth/login" style="color: var(--accent); font-weight: 600;">Sign in</a>
    </p>
  </div>
</div>

<script>
  function formatAadhaar(input) {
    let v = input.value.replace(/\D/g, '').substring(0, 12);
    input.value = v.replace(/(\d{4})(?=\d)/g, '$1 ').trim();
  }

  function showFileName(input, targetId) {
    if (input.files && input.files[0]) {
      document.getElementById(targetId).innerHTML =
        '<i class="fa-solid fa-check-circle" style="color:var(--success);"></i> ' + input.files[0].name;
    }
  }
</script>

<%- include('../layouts/footer') %>
