<%- include('../layouts/main') %>

<div class="container" style="max-width: 850px; margin: 3rem auto; padding: 0 1rem;">
  <div class="p2p-modal-container" style="width: 100%; height: 520px; max-height: none; box-shadow: var(--shadow-md); border: 1px solid var(--border); border-top: 4px solid var(--accent); margin: 0 auto; animation: none; display: block;">
    <div class="p2p-modal-split" style="display: flex; height: 100%; width: 100%;">
      <!-- Left side: Image of smiling girl with phone -->
      <div class="p2p-modal-left" style="width: 48%; height: 100%; overflow: hidden; background: #f8fafc;">
        <img src="/images/login_modal_girl.png" alt="Welcome to RentIt" style="width: 100%; height: 100%; object-fit: cover;">
      </div>
      <!-- Right side: Form controls -->
      <div class="p2p-modal-right" style="width: 52%; padding: 3rem 2.5rem; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;">
        <h2 style="text-align: center; margin-bottom: 0.5rem; font-family: var(--font-display); font-weight: 700; color: #0f172a;">Seller Portal</h2>
        <p style="text-align: center; color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;">Log in to manage your listings, bookings, and earnings.</p>
        
        <form action="/auth/login" method="POST">
          <input type="hidden" name="role" value="seller">
          <div class="form-group" style="text-align: left;">
            <label for="email" class="p2p-input-label" style="font-weight: 700; margin-bottom: 8px; display: block;">Seller Email Address</label>
            <input type="email" name="email" id="email" class="form-control" placeholder="seller@example.com" required style="border-radius: 10px; height: 48px; border: 1px solid #cbd5e1; padding: 0 16px; width: 100%; outline: none; box-sizing: border-box;">
          </div>
          <div class="form-group" style="text-align: left; margin-bottom: 1.5rem;">
            <label for="password" class="p2p-input-label" style="font-weight: 700; margin-bottom: 8px; display: block;">Password</label>
            <input type="password" name="password" id="password" class="form-control" placeholder="Enter your password" required style="border-radius: 10px; height: 48px; border: 1px solid #cbd5e1; padding: 0 16px; width: 100%; outline: none; box-sizing: border-box;">
          </div>
          <button type="submit" class="p2p-continue-btn" style="margin-bottom: 1.5rem; background-color: var(--accent); color: #fff; font-weight: 700; border: none; border-radius: 10px; height: 48px; width: 100%; cursor: pointer;">
            <i class="fa-solid fa-store"></i> Seller Sign In
          </button>
        </form>
        
        <p style="text-align: center; font-size: 0.9rem; color: #64748b; margin: 0;">
          Want to sell on RentIt? <a href="/auth/signup" class="orange-link" style="color: var(--accent); font-weight: 600; text-decoration: none;">Register as a Seller</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
