<%- include('../layouts/main') %>

<style>
  .login-card-container {
    width: 100%;
    height: 520px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
    margin: 0 auto;
    background: var(--surface);
    border-radius: 24px;
    overflow: hidden;
  }
  .login-split {
    display: flex;
    height: 100%;
    width: 100%;
  }
  .login-left {
    width: 48%;
    height: 100%;
    overflow: hidden;
    background: #f8fafc;
  }
  .login-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .login-right {
    width: 52%;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
  }
  
  @media (max-width: 768px) {
    .login-card-container {
      height: auto;
      max-width: 480px;
    }
    .login-split {
      flex-direction: column;
    }
    .login-left {
      display: none;
    }
    .login-right {
      width: 100%;
      padding: 2.5rem 1.5rem;
    }
  }
</style>

<div class="container" style="max-width: 850px; margin: 3rem auto; padding: 0 1rem;">
  <div class="login-card-container">
    <div class="login-split">
      <!-- Left side: Image of smiling girl with phone -->
      <div class="login-left">
        <img src="/images/login_modal_girl.png" alt="Welcome to RentIt">
      </div>
      <!-- Right side: Form controls -->
      <div class="login-right">
        <h2 style="text-align: center; margin-bottom: 1.5rem; font-family: var(--font-display); font-weight: 700; color: #0f172a;">Welcome Back</h2>
        
        <form action="/auth/login" method="POST">
          <input type="hidden" name="role" value="user">
          <div class="form-group" style="text-align: left;">
            <label for="email" class="p2p-input-label" style="font-weight: 700; margin-bottom: 8px; display: block;">Email Address</label>
            <input type="email" name="email" id="email" class="form-control" placeholder="name@example.com" required style="border-radius: 10px; height: 48px; border: 1px solid #cbd5e1; padding: 0 16px; width: 100%; outline: none; box-sizing: border-box;">
          </div>
          <div class="form-group" style="text-align: left; margin-bottom: 1.5rem;">
            <label for="password" class="p2p-input-label" style="font-weight: 700; margin-bottom: 8px; display: block;">Password</label>
            <input type="password" name="password" id="password" class="form-control" placeholder="Enter your password" required style="border-radius: 10px; height: 48px; border: 1px solid #cbd5e1; padding: 0 16px; width: 100%; outline: none; box-sizing: border-box;">
          </div>
          <button type="submit" class="p2p-continue-btn" style="margin-bottom: 1.5rem; background-color: #ff5a00; color: #fff; font-weight: 700; border: none; border-radius: 10px; height: 48px; width: 100%; cursor: pointer;">Sign In</button>
        </form>
        
        <p style="text-align: center; font-size: 0.9rem; color: #64748b; margin: 0;">
          New to RentIt? <a href="/auth/signup" class="orange-link" style="color: #ff5a00; font-weight: 600; text-decoration: none;">Sign Up</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
