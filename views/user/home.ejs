<%- include('../layouts/main') %>

<!-- Curated Premium Theme Styles for User Portal -->
<style>
  .browse-breadcrumbs {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
  }
  .browse-breadcrumbs a {
    color: #ff5a00;
    text-decoration: none;
    font-weight: 600;
  }
  .browse-breadcrumbs a:hover {
    text-decoration: underline;
  }

  .browse-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }

  /* Subcategory Horizontal Pills */
  .subcategory-pills {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    margin-bottom: 1.75rem;
    scrollbar-width: none;
  }
  .subcategory-pills::-webkit-scrollbar {
    display: none;
  }
  .sub-pill {
    background: #ffffff;
    border: 1px solid #ff5a00;
    color: #ff5a00;
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
    text-decoration: none;
  }
  .sub-pill:hover, .sub-pill.active {
    background: #ff5a00;
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(255, 90, 0, 0.2);
  }

  /* Filters Row */
  .filters-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .filter-select {
    padding: 8px 16px;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 0.88rem;
    color: #475569;
    background: #ffffff;
    outline: none;
    cursor: pointer;
    min-width: 180px;
    transition: border-color 0.2s;
  }
  .filter-select:focus {
    border-color: #ff5a00;
  }

  /* Full Width Grid */
  .classic-items-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 1024px) {
    .classic-items-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .classic-items-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .classic-items-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="container" style="max-width: 1200px; padding: 2rem 1.5rem;">
  
  <!-- Breadcrumbs -->
  <div class="browse-breadcrumbs">
    <i class="fa-solid fa-house" style="font-size: 0.8rem;"></i>
    <a href="/">RentIt</a>
    <span>/</span>
    <a href="/items">Browse</a>
    <span>/</span>
    <span style="color: var(--text-primary); font-weight: 600;">
      <%= category === 'all' ? 'All Products' : category.charAt(0).toUpperCase() + category.slice(1) %>
    </span>
  </div>

  <!-- Page Title -->
  <h1 class="browse-title">
    <%= category === 'all' ? 'All Listed Items' : category.charAt(0).toUpperCase() + category.slice(1) %>
  </h1>

  <!-- Subcategory Pills depending on category -->
  <div class="subcategory-pills">
    <% if (category === 'vehicles') { %>
      <a href="/items?category=vehicles" class="sub-pill <%= !subcategory ? 'active' : '' %>">All Vehicles</a>
      <a href="/items?category=vehicles&subcategory=self_drive_car" class="sub-pill <%= subcategory === 'self_drive_car' ? 'active' : '' %>">Self Drive Car</a>
      <a href="/items?category=vehicles&subcategory=bikes_scooters" class="sub-pill <%= subcategory === 'bikes_scooters' ? 'active' : '' %>">Bikes & Scooters</a>
      <a href="/items?category=vehicles&subcategory=outstation_cabs" class="sub-pill <%= subcategory === 'outstation_cabs' ? 'active' : '' %>">Outstation Cabs</a>
      <a href="/items?category=vehicles&subcategory=luxury_cars" class="sub-pill <%= subcategory === 'luxury_cars' ? 'active' : '' %>">Luxury Cars</a>
      <a href="/items?category=vehicles&subcategory=segways" class="sub-pill <%= subcategory === 'segways' ? 'active' : '' %>">Segways</a>
      <a href="/items?category=vehicles&subcategory=golf_cart" class="sub-pill <%= subcategory === 'golf_cart' ? 'active' : '' %>">Golf Cart</a>
      <a href="/items?category=vehicles&subcategory=other" class="sub-pill <%= subcategory === 'other' ? 'active' : '' %>">Others</a>
    <% } else if (category === 'electronics') { %>
      <a href="/items?category=electronics" class="sub-pill <%= !subcategory ? 'active' : '' %>">All Electronics</a>
      <a href="/items?category=electronics&subcategory=mobile" class="sub-pill <%= subcategory === 'mobile' ? 'active' : '' %>">Mobile / Smartphone</a>
      <a href="/items?category=electronics&subcategory=laptop" class="sub-pill <%= subcategory === 'laptop' ? 'active' : '' %>">Laptops & Computers</a>
      <a href="/items?category=electronics&subcategory=camera" class="sub-pill <%= subcategory === 'camera' ? 'active' : '' %>">DSLR Cameras</a>
      <a href="/items?category=electronics&subcategory=tv" class="sub-pill <%= subcategory === 'tv' ? 'active' : '' %>">LED TVs</a>
      <a href="/items?category=electronics&subcategory=audio" class="sub-pill <%= subcategory === 'audio' ? 'active' : '' %>">Audio Systems</a>
      <a href="/items?category=electronics&subcategory=appliances" class="sub-pill <%= subcategory === 'appliances' ? 'active' : '' %>">Home Appliances</a>
      <a href="/items?category=electronics&subcategory=other" class="sub-pill <%= subcategory === 'other' ? 'active' : '' %>">Others</a>
    <% } else if (category === 'tools') { %>
      <a href="/items?category=tools" class="sub-pill <%= !subcategory ? 'active' : '' %>">All Tools</a>
      <a href="/items?category=tools&subcategory=drills" class="sub-pill <%= subcategory === 'drills' ? 'active' : '' %>">Power Drills</a>
      <a href="/items?category=tools&subcategory=saws" class="sub-pill <%= subcategory === 'saws' ? 'active' : '' %>">Saws & Cutters</a>
      <a href="/items?category=tools&subcategory=hand_tools" class="sub-pill <%= subcategory === 'hand_tools' ? 'active' : '' %>">Hand Tools</a>
      <a href="/items?category=tools&subcategory=generators" class="sub-pill <%= subcategory === 'generators' ? 'active' : '' %>">Generators</a>
      <a href="/items?category=tools&subcategory=ladders" class="sub-pill <%= subcategory === 'ladders' ? 'active' : '' %>">Ladders</a>
      <a href="/items?category=tools&subcategory=other" class="sub-pill <%= subcategory === 'other' ? 'active' : '' %>">Others</a>
    <% } else { %>
      <!-- Render main categories if in general view -->
      <a href="/items" class="sub-pill <%= category === 'all' ? 'active' : '' %>">All Categories</a>
      <a href="/items?category=electronics" class="sub-pill <%= category === 'electronics' ? 'active' : '' %>">Electronics</a>
      <a href="/items?category=tools" class="sub-pill <%= category === 'tools' ? 'active' : '' %>">Tools & Gear</a>
      <a href="/items?category=vehicles" class="sub-pill <%= category === 'vehicles' ? 'active' : '' %>">Vehicles</a>
      <a href="/items?category=furniture" class="sub-pill <%= category === 'furniture' ? 'active' : '' %>">Furniture</a>
      <a href="/items?category=sports" class="sub-pill <%= category === 'sports' ? 'active' : '' %>">Sports</a>
      <a href="/items?category=clothing" class="sub-pill <%= category === 'clothing' ? 'active' : '' %>">Clothing</a>
      <a href="/items?category=other" class="sub-pill <%= category === 'other' ? 'active' : '' %>">Others</a>
    <% } %>
  </div>

  <!-- Search Bar for Category/Subcategory -->
  <div style="margin-bottom: 2rem; max-width: 500px;">
    <form action="/items" method="GET" style="display: flex; gap: 8px;">
      <input type="hidden" name="category" value="<%= category %>">
      <% if (subcategory) { %>
        <input type="hidden" name="subcategory" value="<%= subcategory %>">
      <% } %>
      <div style="position: relative; flex: 1;">
        <input type="text" name="search" placeholder="Search in this section..." value="<%= search %>" class="form-control" style="height: 42px; padding-left: 36px; border-radius: 6px; width: 100%; outline: none; border: 1px solid #cbd5e1;">
        <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8;"></i>
      </div>
      <button type="submit" class="btn btn-primary" style="height: 42px; border-radius: 6px; padding: 0 20px; background-color: #ff5a00; border: none; font-weight: 700; color: #fff; cursor: pointer;">Search</button>
    </form>
  </div>

  <!-- Filters Row -->
  <div class="filters-row">
    <div>
      <select class="filter-select" onchange="applySorting(this.value)">
        <option value="price_asc" <%= locals.sort === 'price_asc' ? 'selected' : '' %>>Sort by: Price Low to High</option>
        <option value="price_desc" <%= locals.sort === 'price_desc' ? 'selected' : '' %>>Sort by: Price High to Low</option>
        <option value="newest" <%= locals.sort === 'newest' ? 'selected' : '' %>>Sort by: Newest Listings</option>
      </select>
    </div>

    <div style="display:flex; align-items:center; gap:0.5rem;">
      <i class="fa-solid fa-location-dot" style="color:#ff5a00; font-size:0.9rem;"></i>
      <select id="distance-filter" class="filter-select" onchange="applyDistanceFilter(this.value)" style="min-width:160px;">
        <option value="" <%= !locals.distance || locals.distance === '50' ? '' : '' %>>📍 All Nearby Items</option>
        <option value="3" <%= locals.distance == '3' ? 'selected' : '' %>>Under 3 km</option>
        <option value="5" <%= locals.distance == '5' ? 'selected' : '' %>>Under 5 km</option>
        <option value="10" <%= locals.distance == '10' ? 'selected' : '' %>>Under 10 km</option>
        <option value="50" <%= locals.distance == '50' ? 'selected' : '' %>>Under 50 km</option>
      </select>
    </div>

    <div>
      <select class="filter-select">
        <option>Select Tenure</option>
        <option>1 - 3 Months</option>
        <option>3 - 6 Months</option>
        <option>6+ Months</option>
      </select>
    </div>
  </div>

  <!-- Items Grid -->
  <% if (items.length === 0) { %>
    <div style="text-align: center; padding: 5rem 2rem; background-color: #ffffff; border: 1px dashed var(--border); border-radius: var(--radius-lg);">
      <div style="font-size: 3rem; color: var(--text-hint); margin-bottom: 1.25rem;"><i class="fa-solid fa-box-open"></i></div>
      <h4 style="margin-bottom: 0.5rem; font-family: var(--font-display); font-weight: 700;">No items found</h4>
      <p style="font-size: 0.88rem; color: var(--text-secondary); max-width: 400px; margin: 0 auto 1.5rem;">There are currently no active listings available in this category.</p>
      <a href="/items" class="btn btn-secondary">Clear Filters</a>
    </div>
  <% } else { %>
    <div class="classic-items-grid">
      <% items.forEach(item => { %>
        <%- include('../partials/itemCard', { item }) %>
      <% }) %>
    </div>
  <% } %>

</div>

<script>
  function applySorting(sortVal) {
    const urlParams = new URLSearchParams(window.location.search);
    urlParams.set('sort', sortVal);
    window.location.search = urlParams.toString();
  }

  function applyDistanceFilter(distanceKm) {
    if (!distanceKm) {
      // No distance filter — reload without distance/coords and clear localStorage
      localStorage.removeItem('user_lat');
      localStorage.removeItem('user_lng');
      localStorage.removeItem('user_distance');
      localStorage.setItem('location_cleared', 'true');
      const urlParams = new URLSearchParams(window.location.search);
      urlParams.delete('distance');
      urlParams.delete('lat');
      urlParams.delete('lng');
      window.location.search = urlParams.toString();
      return;
    }

    // Explicit distance chosen - clear the cleared flag
    localStorage.removeItem('location_cleared');

    // Check if we already have coords in URL
    const currentParams = new URLSearchParams(window.location.search);
    if (currentParams.get('lat') && currentParams.get('lng')) {
      localStorage.setItem('user_distance', distanceKm);
      currentParams.set('distance', distanceKm);
      window.location.search = currentParams.toString();
      return;
    }

    // Need geolocation first
    if (!navigator.geolocation) {
      alert('Your browser does not support location. Cannot filter by distance.');
      return;
    }

    const distSelect = document.getElementById('distance-filter');
    if (distSelect) {
      distSelect.disabled = true;
      distSelect.parentElement.insertAdjacentHTML('beforeend',
        '<span id="loc-loading" style="font-size:0.78rem; color:#ff5a00; margin-left:6px;"><i class="fa-solid fa-spinner fa-spin"></i> Getting your location…</span>'
      );
    }

    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const latVal = pos.coords.latitude.toFixed(6);
        const lngVal = pos.coords.longitude.toFixed(6);
        localStorage.setItem('user_lat', latVal);
        localStorage.setItem('user_lng', lngVal);
        localStorage.setItem('user_distance', distanceKm);

        const urlParams = new URLSearchParams(window.location.search);
        urlParams.set('lat', latVal);
        urlParams.set('lng', lngVal);
        urlParams.set('distance', distanceKm);
        window.location.search = urlParams.toString();
      },
      (err) => {
        const loading = document.getElementById('loc-loading');
        if (loading) loading.remove();
        if (distSelect) distSelect.disabled = false;
        alert('Could not get your location. Please enable location permissions and try again.');
      },
      { timeout: 10000, maximumAge: 300000 }
    );
  }

  // Auto-restore or auto-detect distance filter from localStorage/geolocation on load if not present in URL
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    if (!urlParams.get('lat') && !urlParams.get('lng')) {
      // If user explicitly cleared the location filter, don't auto-restore/auto-detect
      if (localStorage.getItem('location_cleared') === 'true') {
        return;
      }

      const storedLat = localStorage.getItem('user_lat');
      const storedLng = localStorage.getItem('user_lng');
      const storedDist = localStorage.getItem('user_distance');

      if (storedLat && storedLng && storedDist) {
        urlParams.set('lat', storedLat);
        urlParams.set('lng', storedLng);
        urlParams.set('distance', storedDist);
        window.location.search = urlParams.toString();
      } else {
        // No stored coordinates - attempt to auto-detect browser physical location
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              const latVal = pos.coords.latitude.toFixed(6);
              const lngVal = pos.coords.longitude.toFixed(6);
              // Save to localStorage
              localStorage.setItem('user_lat', latVal);
              localStorage.setItem('user_lng', lngVal);
              localStorage.setItem('user_distance', '50'); // default to 50km on first load

              urlParams.set('lat', latVal);
              urlParams.set('lng', lngVal);
              urlParams.set('distance', '50');
              window.location.search = urlParams.toString();
            },
            (err) => {
              console.log('Auto-geolocation on page load skipped or denied.');
            },
            { timeout: 6000, maximumAge: 300000 }
          );
        }
      }
    }
  });
</script>

<%- include('../layouts/footer') %>
