<%- include('../layouts/main') %>

<div class="container" style="max-width: 1400px; padding: 1.5rem;">
  
  <!-- Welcome Header Banner -->
  <div style="background: linear-gradient(135deg, var(--primary) 0%, #1e40af 100%); color: #fff; padding: 2rem; border-radius: var(--radius-lg); margin-bottom: 2rem; box-shadow: var(--shadow-sm); position: relative; overflow: hidden;">
    <div style="position: absolute; right: -20px; bottom: -20px; opacity: 0.15; font-size: 10rem; transform: rotate(-15deg);">
      <i class="fa-solid fa-basket-shopping"></i>
    </div>
    <h2 style="font-family: var(--font-display); font-size: 2rem; margin-bottom: 0.5rem; font-weight: 700; color:#ffffff;">Welcome back, <%= currentUser ? currentUser.name : 'Renter' %>! 👋</h2>
    <p style="font-size: 1.05rem; opacity: 0.95; margin: 0; max-width: 650px;">
      Find premium items to rent under 5 km from your current location. Search for products or choose a category below.
    </p>
  </div>

  <!-- What do you want to rent (Category Cards Grid) -->
  <div style="margin-bottom: 2rem;">
    <h3 style="font-family: var(--font-display); font-size: 1.25rem; margin-bottom: 1rem; font-weight: 700; color: var(--text-primary);">What do you want to rent?</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 1rem;">
      <%
        const categoriesList = [
          { value: 'electronics', label: 'Electronics', icon: 'fa-laptop' },
          { value: 'tools', label: 'Tools', icon: 'fa-screwdriver-wrench' },
          { value: 'vehicles', label: 'Vehicles', icon: 'fa-car' },
          { value: 'furniture', label: 'Furniture', icon: 'fa-couch' },
          { value: 'sports', label: 'Sports', icon: 'fa-volleyball' },
          { value: 'clothing', label: 'Clothing', icon: 'fa-shirt' },
          { value: 'other', label: 'Other', icon: 'fa-box-open' }
        ];
      %>
      <% categoriesList.forEach(cat => { %>
        <div class="category-card <%= category === cat.value ? 'active' : '' %>" onclick="selectCategory('<%= cat.value %>')">
          <div class="cat-icon-wrapper"><i class="fa-solid <%= cat.icon %>"></i></div>
          <div style="font-size: 0.85rem; font-weight: 600;"><%= cat.label %></div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Filter & Search Panel -->
  <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; box-shadow: var(--shadow-sm); margin-bottom: 2rem;">
    <form action="/items" method="GET" id="search-form">
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
        
        <!-- Search Input -->
        <div style="flex: 2; min-width: 250px; position: relative;">
          <label style="font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px; display: block;">Keywords</label>
          <div style="display: flex;">
            <input type="text" name="search" id="search-input" value="<%= search %>" class="form-control" placeholder="Search items e.g., DSLR camera..." style="height: 42px; width: 100%;" autocomplete="off">
          </div>
          <!-- Autocomplete results dropdown -->
          <div id="autocomplete-results" style="display: none; position: absolute; top: 70px; left: 0; right: 0; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); box-shadow: var(--shadow-md); z-index: 2000; max-height: 250px; overflow-y: auto;">
          </div>
        </div>

        <!-- Smart Search Switcher -->
        <div style="flex: 1.5; min-width: 200px;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <label style="font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin: 0;">✦ Smart Search</label>
            <label class="switch" style="display: flex; align-items: center; gap: 4px; font-size: 0.75rem; font-weight: 600; color: var(--primary); cursor: pointer; margin: 0;">
              <input type="checkbox" id="smart-search-toggle" <%= smartSearch ? 'checked' : '' %>> AI Search
            </label>
          </div>
          <input type="text" name="smartSearch" id="smart-search-input" value="<%= smartSearch %>" class="form-control" placeholder="AI query e.g., Camera under ₹1000..." style="display: <%= smartSearch ? 'block' : 'none' %>; height: 42px;">
        </div>

        <!-- Category Dropdown Hidden Selector -->
        <input type="hidden" name="category" id="category-hidden-input" value="<%= category %>">

        <!-- Distance Range Selector -->
        <div style="width: 150px;">
          <label style="font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px; display: block;">Max Distance</label>
          <select name="distance" class="form-control" style="height: 42px; font-size: 0.85rem;" onchange="this.form.submit()">
            <option value="1" <%= distance === '1' ? 'selected' : '' %>>Within 1 km</option>
            <option value="5" <%= distance === '5' ? 'selected' : '' %>>Within 5 km</option>
            <option value="10" <%= distance === '10' ? 'selected' : '' %>>Within 10 km</option>
            <option value="50" <%= distance === '50' ? 'selected' : '' %>>Within 50 km</option>
          </select>
        </div>

        <!-- Price Range Slider -->
        <div style="flex: 1; min-width: 180px;">
          <div style="display: flex; justify-content: space-between; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px;">
            <span>Max Price / Day</span>
            <span id="price-val">₹<%= maxPrice || '2000' %></span>
          </div>
          <input type="range" name="maxPrice" id="price-slider" min="0" max="5000" step="50" value="<%= maxPrice || '2000' %>" style="width: 100%; accent-color: var(--primary); margin-top: 10px;">
        </div>

        <!-- Hidden coordinates -->
        <input type="hidden" name="lng" id="lng-input" value="<%= lng %>">
        <input type="hidden" name="lat" id="lat-input" value="<%= lat %>">

        <!-- Filter Submit Button -->
        <div>
          <button type="submit" class="btn btn-primary" style="height: 42px; padding: 0 20px;"><i class="fa-solid fa-filter"></i> Apply</button>
        </div>
      </div>
    </form>
    
    <% if (aiExplanation) { %>
      <div style="background-color: #eff6ff; border-left: 3px solid var(--primary); padding: 10px 14px; border-radius: var(--radius-sm); font-size: 0.825rem; color: var(--text-secondary); margin-top: 1rem; display: flex; align-items: center; gap: 8px;">
        <i class="fa-solid fa-robot" style="color: var(--primary);"></i> <span><%= aiExplanation %></span>
      </div>
    <% } %>
  </div>

  <!-- Main Listing Grid Section -->
  <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: flex-start;">
    
    <!-- Left: Classic Grid Listing (70% width) -->
    <div style="flex: 3; min-width: 320px;">
      <h3 style="font-size: 1.3rem; font-family: var(--font-display); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <span>Available items near you</span>
        <span style="font-size: 0.9rem; color: var(--text-secondary); font-weight: 400;"><%= items.length %> items found within <%= distance %> km</span>
      </h3>

      <% if (items.length === 0) { %>
        <div style="text-align: center; padding: 4rem 2rem; background-color: var(--surface); border: 1px dashed var(--border); border-radius: var(--radius-lg); margin-bottom: 2rem;">
          <div style="font-size: 3rem; color: var(--text-hint); margin-bottom: 1.25rem;"><i class="fa-solid fa-couch"></i></div>
          <h4 style="margin-bottom: 0.5rem; font-family: var(--font-display);">No items found in this range</h4>
          <p style="font-size: 0.88rem; color: var(--text-secondary); max-width: 400px; margin: 0 auto 1.5rem;">Try resetting your filters or increasing the search distance to find options farther away.</p>
          <a href="/user/home" class="btn btn-secondary"><i class="fa-solid fa-rotate-left"></i> Reset Search</a>
        </div>
      <% } else { %>
        <div class="classic-items-grid">
          <% items.forEach(item => { %>
            <%- include('../partials/itemCard', { item }) %>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Right: Compact Map Card & Current Location Details (30% width) -->
    <div style="flex: 1.2; min-width: 300px; position: sticky; top: 90px;">
      <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); margin-bottom: 1.5rem;">
        <h4 style="font-family: var(--font-display); font-size: 1.05rem; margin-bottom: 0.75rem; font-weight: 700; display: flex; align-items: center; gap: 8px;">
          <i class="fa-solid fa-map-location-dot" style="color: var(--primary);"></i> Nearby Rentals Map
        </h4>
        <div style="height: 280px; border-radius: var(--radius-md); overflow: hidden; margin-bottom: 1rem; border: 1px solid var(--border); position: relative;">
          <div id="map" style="height: 100%;"></div>
          <button id="locate-btn" class="btn btn-surface" style="position: absolute; top: 8px; right: 8px; z-index: 1000; background: #fff; box-shadow: var(--shadow-sm); padding: 6px 10px; font-size: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer;">
            <i class="fa-solid fa-crosshairs"></i> Use My Location
          </button>
        </div>
        <div style="background: #f8fafc; border-radius: var(--radius-sm); padding: 0.75rem; border: 1px solid var(--border); margin-bottom: 0.5rem;">
          <div style="font-size: 0.78rem; color: var(--text-hint); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; margin-bottom: 2px;">Your Stored GPS Coordinates</div>
          <div style="font-size: 0.85rem; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 6px;">
            <i class="fa-solid fa-location-crosshairs" style="color: var(--primary);"></i>
            <span id="coords-text"><%= lat ? parseFloat(lat).toFixed(5) : '19.0760' %>, <%= lng ? parseFloat(lng).toFixed(5) : '72.8777' %></span>
          </div>
        </div>
        <p style="font-size: 0.78rem; color: var(--text-secondary); margin: 0; line-height: 1.45;">
          Pins show items listed near you. Double click on the map to manually set your location point, or click the crosshair button to auto-detect location.
        </p>
      </div>
    </div>

  </div>
</div>

<script>
  // Function to set category from category cards
  function selectCategory(catVal) {
    const activeCat = document.getElementById('category-hidden-input').value;
    if (activeCat === catVal) {
      // Toggle off
      document.getElementById('category-hidden-input').value = 'all';
    } else {
      document.getElementById('category-hidden-input').value = catVal;
    }
    document.getElementById('search-form').submit();
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Dynamic Price slider value label
    const priceSlider = document.getElementById('price-slider');
    const priceVal    = document.getElementById('price-val');
    priceSlider.addEventListener('input', () => {
      priceVal.textContent = '₹' + priceSlider.value;
    });

    // Smart Search input toggle
    const smartSearchToggle = document.getElementById('smart-search-toggle');
    const standardInput     = document.getElementById('search-input');
    const smartInput        = document.getElementById('smart-search-input');
    
    smartSearchToggle.addEventListener('change', () => {
      if (smartSearchToggle.checked) {
        smartInput.style.display = 'block';
        standardInput.disabled   = true;
        standardInput.value      = '';
      } else {
        smartInput.style.display = 'none';
        smartInput.value         = '';
        standardInput.disabled   = false;
      }
    });
    if (smartSearchToggle.checked) standardInput.disabled = true;

    // Current coordinates (defaults to Mumbai)
    let lng = parseFloat(document.getElementById('lng-input').value) || 72.8777;
    let lat = parseFloat(document.getElementById('lat-input').value) || 19.0760;

    // Initialize Map centered on user location
    const map = L.map('map').setView([lat, lng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap'
    }).addTo(map);

    // Pulsing blue user pin
    const userPinHtml = `
      <div style="position:relative;">
        <div style="background:var(--primary);width:16px;height:16px;border:3px solid white;border-radius:50%;box-shadow:0 0 12px rgba(37,99,235,.5);"></div>
        <div style="position:absolute;top:-4px;left:-4px;width:24px;height:24px;border:2px solid rgba(37,99,235,.4);border-radius:50%;animation:ping 1.5s ease-in-out infinite;"></div>
      </div>`;
    const userIcon = L.divIcon({
      html: userPinHtml,
      className: 'custom-div-icon',
      iconSize: [16, 16],
      iconAnchor: [8, 8]
    });
    const userMarker = L.marker([lat, lng], { icon: userIcon })
      .addTo(map).bindPopup('<b>📍 Your Location</b>').openPopup();

    // Radius circle showing search limit
    let radiusCircle = L.circle([lat, lng], {
      radius: parseFloat(document.querySelector('select[name="distance"]').value) * 1000,
      color: '#2563EB', weight: 1.5, fillColor: '#2563EB', fillOpacity: 0.05
    }).addTo(map);

    // Item pins
    const itemsData = <%- JSON.stringify(items) %>;
    itemsData.forEach(item => {
      if (item.location && item.location.coordinates) {
        const iLng = item.location.coordinates[0];
        const iLat = item.location.coordinates[1];
        const distKm = item.dist && item.dist.calculated != null
          ? (item.dist.calculated / 1000).toFixed(1) : null;
        const distLabel = distKm ? `${distKm} km away` : '';

        const pin = L.divIcon({
          html: `<div style="background:var(--accent);width:14px;height:14px;border:3px solid white;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,.25);"></div>`,
          className: 'custom-div-icon', iconSize: [14, 14], iconAnchor: [7, 7]
        });

        L.marker([iLat, iLng], { icon: pin }).addTo(map).bindPopup(`
          <div style="width:160px; font-family: var(--font);">
            <h4 style="margin:0 0 4px; font-size:13px; font-weight:700;">${item.title}</h4>
            <p style="margin:0 0 4px; font-size:12px; color:var(--accent); font-weight:700;">₹${item.pricePerDay}/day</p>
            ${distLabel ? `<p style="margin:0 0 6px; font-size:11px; color:#475569;"><i class="fa-solid fa-location-dot"></i> ${distLabel}</p>` : ''}
            <a href="/items/${item._id}" style="display:block; background:var(--primary); color:#fff; font-size:11px; text-align:center; padding:5px; border-radius:4px; text-decoration:none; font-weight:600;">View Details</a>
          </div>`);
      }
    });

    // Update circle when distance changes
    document.querySelector('select[name="distance"]').addEventListener('change', function() {
      map.removeLayer(radiusCircle);
      radiusCircle = L.circle([lat, lng], {
        radius: parseFloat(this.value) * 1000,
        color: '#2563EB', weight: 1.5, fillColor: '#2563EB', fillOpacity: 0.05
      }).addTo(map);
    });

    // Geolocation handlers
    function haversineKm(lat1, lng1, lat2, lng2) {
      const R = 6371;
      const dLat = (lat2-lat1)*Math.PI/180;
      const dLng = (lng2-lng1)*Math.PI/180;
      const a = Math.sin(dLat/2)*Math.sin(dLat/2) +
                Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*
                Math.sin(dLng/2)*Math.sin(dLng/2);
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    }

    async function saveLocationToServer(newLat, newLng) {
      try {
        const res = await fetch('/user/location/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lat: newLat, lng: newLng })
        });
        return await res.json();
      } catch(e) { return { success: false }; }
    }

    function applyNewLocation(newLat, newLng, forceRefresh = false) {
      document.getElementById('lng-input').value = newLng;
      document.getElementById('lat-input').value = newLat;
      document.getElementById('coords-text').textContent = newLat.toFixed(5) + ', ' + newLng.toFixed(5);
      map.setView([newLat, newLng], 14);
      userMarker.setLatLng([newLat, newLng]).openPopup();
      radiusCircle.setLatLng([newLat, newLng]);
      lng = newLng; lat = newLat;
      if (forceRefresh) document.getElementById('search-form').submit();
    }

    // Auto-detect location on load (only if moved > 200m)
    <% if (currentUser) { %>
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(async (position) => {
          const newLat = position.coords.latitude;
          const newLng = position.coords.longitude;
          const movedKm = haversineKm(lat, lng, newLat, newLng);

          if (movedKm > 0.2) {
            const saved = await saveLocationToServer(newLat, newLng);
            if (saved.success) {
              const toast = document.createElement('div');
              toast.innerHTML = `<i class="fa-solid fa-location-crosshairs"></i> GPS location updated. Refreshing listings...`;
              toast.style.cssText = `position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--primary);color:#fff;padding:10px 20px;border-radius:99px;font-size:0.85rem;z-index:2000;box-shadow:0 4px 12px rgba(0,0,0,.2);`;
              document.body.appendChild(toast);
              setTimeout(() => applyNewLocation(newLat, newLng, true), 1200);
            } else {
              applyNewLocation(newLat, newLng, false);
            }
          }
        }, () => {
          console.log('Location access not permitted.');
        }, { enableHighAccuracy: true, timeout: 8000 });
      }
    <% } %>

    // "Use My Location" action
    const locateBtn = document.getElementById('locate-btn');
    locateBtn.addEventListener('click', () => {
      if (!navigator.geolocation) {
        alert('Geolocation is not supported by this browser.');
        return;
      }
      locateBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Detecting...';
      locateBtn.disabled = true;

      navigator.geolocation.getCurrentPosition(async (position) => {
        const newLat = position.coords.latitude;
        const newLng = position.coords.longitude;
        await saveLocationToServer(newLat, newLng);
        applyNewLocation(newLat, newLng, true);
      }, (err) => {
        locateBtn.innerHTML = '<i class="fa-solid fa-crosshairs"></i> Use My Location';
        locateBtn.disabled = false;
        alert('Could not determine location: ' + err.message);
      }, { enableHighAccuracy: true, timeout: 10000 });
    });

    // Autocomplete logic
    const searchInput = document.getElementById('search-input');
    const autocompleteResults = document.getElementById('autocomplete-results');
    let debounceTimeout;

    // Autocomplete selection handler
    window.selectAutocompleteItem = function(title) {
      document.getElementById('search-input').value = title;
      document.getElementById('autocomplete-results').style.display = 'none';
      document.getElementById('search-form').submit();
    };

    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimeout);
      const query = searchInput.value.trim();
      if (query.length < 2) {
        autocompleteResults.style.display = 'none';
        autocompleteResults.innerHTML = '';
        return;
      }

      debounceTimeout = setTimeout(async () => {
        try {
          const res = await fetch(`/items/autocomplete?query=${encodeURIComponent(query)}`);
          const data = await res.json();
          if (data.success && data.items && data.items.length > 0) {
            autocompleteResults.innerHTML = data.items.map(item => `
              <div class="autocomplete-item" onclick="selectAutocompleteItem('${item.title.replace(/'/g, "\\'")}')" style="padding: 10px 14px; cursor: pointer; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; transition: background 0.15s ease;">
                <div>
                  <div style="font-weight: 600; font-size: 0.88rem; color: var(--text-primary);">${item.title}</div>
                  <div style="font-size: 0.72rem; color: var(--text-secondary); text-transform: uppercase;">${item.category}</div>
                </div>
                <div style="font-weight: 700; font-size: 0.85rem; color: var(--accent);">₹${item.pricePerDay}/day</div>
              </div>
            `).join('');
            autocompleteResults.style.display = 'block';
          } else {
            autocompleteResults.style.display = 'none';
            autocompleteResults.innerHTML = '';
          }
        } catch (err) {
          console.error(err);
        }
      }, 250);
    });

    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !autocompleteResults.contains(e.target)) {
        autocompleteResults.style.display = 'none';
      }
    });
  });
</script>

<style>
  .autocomplete-item:hover {
    background-color: #f1f5f9 !important;
  }

  .classic-items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .category-card {
    background: var(--surface);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .category-card.active {
    background: var(--primary) !important;
    border-color: var(--primary) !important;
    color: #fff !important;
  }

  .cat-icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(37, 99, 235, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: var(--primary);
    transition: all 0.2s ease;
  }

  .category-card.active .cat-icon-wrapper {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .category-card:hover .cat-icon-wrapper {
    transform: scale(1.1);
  }

  @keyframes ping {
    0%   { transform: scale(1);   opacity: 0.7; }
    70%  { transform: scale(2.2); opacity: 0;   }
    100% { transform: scale(1);   opacity: 0;   }
  }
</style>

<%- include('../layouts/footer') %>
