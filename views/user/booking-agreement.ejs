<%- include('../layouts/main') %>

<style>
  @media print {
    header, footer, nav, .sidebar-nav, .sidebar-toggle, .btn, button, .no-print, .browse-breadcrumbs, #sidebarNav, .sidebar-brand {
      display: none !important;
    }
    body {
      background: #ffffff !important;
      color: #000000 !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    .container {
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    .agreement-card {
      box-shadow: none !important;
      border: none !important;
      padding: 0 !important;
    }
  }

  .agreement-body h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: #0f172a;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 4px;
  }
  .agreement-body p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #334155;
    margin-bottom: 0.75rem;
  }
  .agreement-body ul {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }
  .agreement-body li {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #334155;
    margin-bottom: 0.4rem;
  }
</style>

<div class="container" style="max-width: 800px; padding: 2rem 1rem;">
  
  <div class="no-print" style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
    <a href="/bookings/<%= booking._id %>" class="btn btn-outline" style="display: inline-flex; align-items: center; gap: 6px;">
      <i class="fa-solid fa-arrow-left"></i> Back to Invoice
    </a>
    <button onclick="window.print()" class="btn btn-primary" style="background-color: #ff5a00; border-color: #ff5a00; color: #fff; display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
      <i class="fa-solid fa-print"></i> Print Agreement
    </button>
  </div>

  <div class="agreement-card" style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 3rem; box-shadow: var(--shadow-md);">
    
    <div style="text-align: center; border-bottom: 2px double var(--border); padding-bottom: 1.5rem; margin-bottom: 2rem;">
      <div style="font-size: 0.8rem; text-transform: uppercase; font-weight: 700; color: #ff5a00; letter-spacing: 0.08em; margin-bottom: 4px;">RentIt Secure P2P Agreement</div>
      <h1 style="font-family: var(--font-display); font-size: 1.8rem; font-weight: 800; color: #0f172a; margin: 0;">RENTAL AGREEMENT CONTRACT</h1>
      <p style="font-size: 0.82rem; color: var(--text-secondary); margin: 6px 0 0;">Digitally generated and authorized via RentIt Marketplace</p>
    </div>

    <!-- Contract Details (HTML generated by Gemini) -->
    <div class="agreement-body">
      <%- agreement %>
    </div>

    <!-- Signatures section at bottom -->
    <div style="margin-top: 3.5rem; border-top: 1px solid var(--border); padding-top: 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; text-align: center;">
      <div>
        <div style="height: 50px; display: flex; align-items: center; justify-content: center; font-family: 'Courier New', Courier, monospace; font-size: 1rem; color: #64748b; font-style: italic;">
          Digitally Signed via RentIt
        </div>
        <div style="border-top: 1px solid #cbd5e1; width: 80%; margin: 0 auto; padding-top: 6px; font-weight: 600; font-size: 0.85rem; color: #1e293b;">
          <%= booking.renter.name %> (Renter)
        </div>
      </div>
      <div>
        <div style="height: 50px; display: flex; align-items: center; justify-content: center; font-family: 'Courier New', Courier, monospace; font-size: 1rem; color: #64748b; font-style: italic;">
          Digitally Signed via RentIt
        </div>
        <div style="border-top: 1px solid #cbd5e1; width: 80%; margin: 0 auto; padding-top: 6px; font-weight: 600; font-size: 0.85rem; color: #1e293b;">
          <%= booking.seller.name %> (Seller)
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('../layouts/footer') %>
