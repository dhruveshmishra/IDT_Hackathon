<%- include('../layouts/main') %>

<div class="container" style="max-width: 900px; padding: 1.5rem;">
  <div class="chat-container">
    
    <!-- Chat Sidebar: Conversation metadata / summary -->
    <div class="chat-sidebar" style="background-color: #fafbfd; display: flex; flex-direction: column;">
      <div class="chat-sidebar-header">
        <h3 style="font-family: var(--font-display); font-size: 1.1rem; display: flex; align-items: center; gap: 8px;">
          <i class="fa-regular fa-comment-dots" style="color: var(--primary);"></i> Conversations
        </h3>
      </div>
      <div style="padding: 1rem; border-bottom: 1px solid var(--border);">
        <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 12px; display: flex; flex-direction: column; gap: 6px;">
          <h4 style="font-size: 0.85rem; text-transform: uppercase; color: var(--text-secondary);">Booking Details</h4>
          <p style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);"><%= booking.item ? booking.item.title : 'Deleted Item' %></p>
          <span style="font-size: 0.8rem; font-weight: 600; padding: 2px 6px; border-radius: 4px; background-color: #eff6ff; color: var(--primary); align-self: flex-start;">
            <%= booking.status %>
          </span>
          <div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 4px;">
            <div>Deposit: ₹<%= booking.deposit %></div>
            <div>Total: <strong>₹<%= booking.totalAmount %></strong></div>
          </div>
        </div>
      </div>
      <div style="flex: 1; padding: 1rem; color: var(--text-hint); font-size: 0.85rem; text-align: center;">
        Select an active conversation to respond in real-time.
      </div>
    </div>

    <!-- Active Chat Room Area -->
    <div class="chat-main">
      
      <!-- Top header bar -->
      <div class="chat-header">
        <% 
          let counterParty = (currentUser._id.equals(booking.renter._id)) ? booking.seller : booking.renter;
        %>
        <% if (counterParty.avatar && counterParty.avatar.url) { %>
          <img src="<%= counterParty.avatar.url %>" class="chat-conversation-avatar" style="width: 36px; height: 36px;" alt="avatar">
        <% } else { %>
          <div style="width: 36px; height: 36px; border-radius: 50%; background-color:#cbd5e1; display:flex; align-items:center; justify-content:center; font-weight:700;"><%= counterParty.name[0] %></div>
        <% } %>
        <div>
          <h4 style="margin: 0; font-size: 0.95rem; font-family: var(--font-display);"><%= counterParty.name %></h4>
          <span style="font-size: 0.75rem; color: var(--text-secondary);">Online</span>
        </div>
      </div>

      <!-- Messages Thread -->
      <div class="chat-messages" id="messages-container">
        <!-- Filled dynamically on client init & socket messages -->
      </div>

      <!-- AI Smart Replies Chips -->
      <div id="ai-smart-replies-container" style="display: flex; gap: 8px; padding: 10px 1.25rem; background: #f8fafc; border-top: 1px solid var(--border); overflow-x: auto; scrollbar-width: none; align-items: center;">
        <span style="font-size: 0.75rem; font-weight: 700; color: #64748b; display: flex; align-items: center; gap: 4px; white-space: nowrap;"><i class="fa-solid fa-wand-magic-sparkles" style="color: #ff5a00;"></i> Smart Reply:</span>
        <div id="ai-replies-chips" style="display: flex; gap: 8px; flex-wrap: nowrap; overflow-x: auto;">
          <!-- Loaded dynamically -->
        </div>
      </div>

      <!-- Message input block -->
      <form id="chat-form" class="chat-input-area" style="position: relative; padding: 10px;">
        <textarea id="chat-input-msg" placeholder="Type your message here..." required style="padding-right: 130px; width: 100%; min-height: 50px; border-radius: 8px; border: 1px solid var(--border); outline: none; padding: 10px; box-sizing: border-box; resize: none; font-size: 0.9rem; font-family: inherit;"></textarea>
        <div style="position: absolute; right: 18px; bottom: 18px; display: flex; gap: 6px;">
          <button type="button" id="improve-tone-btn" class="btn btn-outline" style="height: 34px; font-size: 0.78rem; border-color: #3b82f6; color: #3b82f6; font-weight: 700; background: #ffffff; padding: 0 10px; cursor: pointer; display: flex; align-items: center; gap: 4px; border-radius: 6px;" title="Improve Message Tone with AI">
            <i class="fa-solid fa-wand-magic-sparkles"></i> AI Tone
          </button>
          <button type="submit" class="btn btn-primary" style="height: 34px; padding: 0 12px; background-color: #ff5a00; border-color: #ff5a00; border-radius: 6px; color: #fff;"><i class="fa-solid fa-paper-plane"></i></button>
        </div>
      </form>

    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const bookingId = '<%= booking._id %>';
    const senderId = '<%= currentUser._id %>';
    const receiverId = '<%= (currentUser._id.equals(booking.renter._id)) ? booking.seller._id : booking.renter._id %>';
    const messagesContainer = document.getElementById('messages-container');
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input-msg');
    const improveToneBtn = document.getElementById('improve-tone-btn');
    
    let allMessages = [];

    // Socket Connection
    const socket = io();
    socket.emit('join-room', bookingId);

    // Fetch conversation message history
    try {
      const response = await fetch(`/chat/${bookingId}/history`);
      const data = await response.json();
      if (data.success) {
        data.messages.forEach(msg => appendMessage(msg));
        scrollToBottom();
        fetchSmartReplies();
      }
    } catch(err) {
      console.error('History fetch error:', err.message);
    }

    // Dynamic message bubble appender
    function appendMessage(msg) {
      const bubble = document.createElement('div');
      bubble.classList.add('chat-message-bubble');
      
      const isOutgoing = msg.sender === senderId || (msg.sender && msg.sender._id === senderId);
      bubble.classList.add(isOutgoing ? 'outgoing' : 'incoming');
      
      bubble.textContent = msg.text;
      messagesContainer.appendChild(bubble);
      
      allMessages.push({
        senderName: isOutgoing ? 'You' : 'Counterparty',
        text: msg.text
      });
      
      scrollToBottom();
    }

    function scrollToBottom() {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // Smart replies fetch
    async function fetchSmartReplies() {
      const chipsContainer = document.getElementById('ai-replies-chips');
      chipsContainer.innerHTML = '<span style="font-size:0.75rem; color:#94a3b8;">Generating replies...</span>';
      try {
        const itemTitle = '<%= booking.item ? booking.item.title : "" %>';
        const res = await fetch('/ai/chat/replies', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            history: allMessages.slice(-5),
            title: itemTitle
          })
        });
        const data = await res.json();
        if (data.success && data.replies) {
          chipsContainer.innerHTML = '';
          data.replies.forEach(reply => {
            const chip = document.createElement('button');
            chip.type = 'button';
            chip.style.cssText = `
              background: #ffffff;
              border: 1px solid #ff5a00;
              color: #ff5a00;
              padding: 4px 10px;
              border-radius: 12px;
              font-size: 0.75rem;
              font-weight: 600;
              cursor: pointer;
              transition: all 0.2s;
              white-space: nowrap;
            `;
            chip.onmouseover = () => {
              chip.style.background = '#ff5a00';
              chip.style.color = '#ffffff';
            };
            chip.onmouseout = () => {
              chip.style.background = '#ffffff';
              chip.style.color = '#ff5a00';
            };
            chip.textContent = reply;
            chip.onclick = () => {
              chatInput.value = reply;
              chatInput.focus();
            };
            chipsContainer.appendChild(chip);
          });
        }
      } catch (err) {
        console.error('Smart replies error:', err.message);
        chipsContainer.innerHTML = '';
      }
    }

    // Submit send event
    chatForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const messageText = chatInput.value.trim();
      if (!messageText) return;

      const payload = {
        bookingId,
        senderId,
        receiverId,
        text: messageText
      };

      // Emit to server socket handler
      socket.emit('send-message', payload);
      
      chatInput.value = '';
      chatInput.focus();
    });

    // Handle incoming socket message
    socket.on('receive-message', (msg) => {
      appendMessage(msg);
      fetchSmartReplies();
    });

    // Improve tone handler
    improveToneBtn.onclick = async () => {
      const originalVal = chatInput.value.trim();
      if (!originalVal) return;
      improveToneBtn.disabled = true;
      improveToneBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Improving...';
      try {
        const res = await fetch('/ai/chat/optimize-tone', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: originalVal })
        });
        const data = await res.json();
        if (data.success && data.optimized) {
          chatInput.value = data.optimized;
        }
      } catch (err) {
        console.error('Improve tone error:', err.message);
      } finally {
        improveToneBtn.disabled = false;
        improveToneBtn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> AI Tone';
      }
    };
  });
</script>

<%- include('../layouts/footer') %>
