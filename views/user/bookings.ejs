<%- include('../layouts/main') %>

<div class="container" style="max-width: 1000px;">
  <h2 style="font-family: var(--font-display); font-size: 1.8rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 8px;">
    <i class="fa-solid fa-receipt" style="color: var(--primary);"></i> My Booking History
  </h2>

  <% if (bookings.length === 0) { %>
    <div style="text-align: center; padding: 4rem 2rem; background-color: var(--surface); border: 1px dashed var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);">
      <div style="font-size: 3rem; color: var(--text-hint); margin-bottom: 1.25rem;"><i class="fa-solid fa-calendar-xmark"></i></div>
      <h3 style="margin-bottom: 0.5rem; font-family: var(--font-display);">No Bookings Found</h3>
      <p style="color: var(--text-secondary); max-width: 400px; margin: 0 auto 1.5rem;">You haven't rented any items yet. Start exploring the marketplace to find tools, electronics, or gear near you!</p>
      <a href="/items" class="btn btn-primary">Browse Marketplace</a>
    </div>
  <% } else { %>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <% bookings.forEach(booking => { %>
        <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          
          <div style="display: flex; gap: 1.25rem; align-items: center;">
            <% if (booking.item && booking.item.images && booking.item.images.length > 0) { %>
              <img src="<%= booking.item.images[0].url %>" style="width: 80px; height: 80px; border-radius: var(--radius-md); object-fit: cover; background-color: #f1f5f9;">
            <% } else { %>
              <div style="width: 80px; height: 80px; border-radius: var(--radius-md); background-color: #e2e8f0; display: flex; align-items: center; justify-content: center; color: var(--text-hint); font-size: 1.5rem;">
                <i class="fa-solid fa-camera"></i>
              </div>
            <% } %>
            <div>
              <h3 style="font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 0.25rem;">
                <%= booking.item ? booking.item.title : 'Deleted Item' %>
              </h3>
              <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 0.25rem;">
                Seller: <strong><%= booking.seller ? booking.seller.name : 'Unknown Seller' %></strong>
              </p>
              <p style="font-size: 0.85rem; color: var(--text-secondary);">
                Dates: <strong><%= new Date(booking.startDate).toLocaleDateString() %></strong> to <strong><%= new Date(booking.endDate).toLocaleDateString() %></strong> (<%= booking.totalDays %> days)
              </p>
            </div>
          </div>

          <div style="text-align: right; display: flex; flex-direction: column; gap: 8px; align-items: flex-end;">
            <div>
              <span style="font-size: 0.75rem; text-transform: uppercase; font-weight: 700; padding: 4px 8px; border-radius: var(--radius-sm);
                <%= booking.status === 'confirmed' ? 'background-color: #dcfce7; color: #16a34a;' : '' %>
                <%= booking.status === 'pending' ? 'background-color: #fef3c7; color: #d97706;' : '' %>
                <%= booking.status === 'active' ? 'background-color: #eff6ff; color: #2563eb;' : '' %>
                <%= booking.status === 'completed' ? 'background-color: #f1f5f9; color: #64748b;' : '' %>
                <%= booking.status === 'cancelled' ? 'background-color: #fee2e2; color: #dc2626;' : '' %>
              ">
                <%= booking.status %>
              </span>
              <span style="font-size: 0.75rem; text-transform: uppercase; font-weight: 700; padding: 4px 8px; border-radius: var(--radius-sm); margin-left: 4px;
                <%= booking.payment.status === 'paid' ? 'background-color: #dcfce7; color: #16a34a;' : 'background-color: #fee2e2; color: #dc2626;' %>
              ">
                <%= booking.payment.status %>
              </span>
            </div>

            <div style="font-weight: 700; font-size: 1.2rem; color: var(--text-primary);">
              ₹<%= booking.totalAmount %>
            </div>

            <div style="display: flex; gap: 8px;">
              <% if (booking.payment && booking.payment.status === 'paid') { %>
                <a href="/bookings/<%= booking._id %>" class="btn btn-primary" style="padding: 6px 12px; font-size: 0.8rem; background-color: #ff5a00; border-color: #ff5a00; color: #fff;">
                  <i class="fa-solid fa-file-invoice"></i> View Invoice
                </a>
              <% } %>
              <a href="/user/chat/<%= booking._id %>" class="btn btn-outline" style="padding: 6px 12px; font-size: 0.8rem;">
                <i class="fa-regular fa-comment-dots"></i> Message Seller
              </a>
              <% if (booking.status === 'pending') { %>
                <form action="/bookings/<%= booking._id %>/cancel?_method=PUT" method="POST">
                  <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;" onclick="return confirm('Cancel this booking?')">Cancel</button>
                </form>
              <% } %>
            </div>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
