<%- include('../layouts/main') %>
<% locals.activePage = 'profile'; %>

<div class="container">
  <!-- Page Header -->
  <div style="margin-bottom: 2rem;">
    <h1 style="font-size: 1.8rem; margin-bottom: 0.25rem;">My Profile</h1>
    <p style="color: var(--text-secondary);">Manage your account, address, and Aadhaar verification.</p>
  </div>

  <div class="profile-layout">
    <!-- Left: Avatar + Summary -->
    <div>
      <div class="profile-sidebar-card">
        <div class="profile-avatar-wrapper">
          <div class="profile-avatar">
            <% if (currentUser.avatar && currentUser.avatar.url) { %>
              <img src="<%= currentUser.avatar.url %>" alt="Profile avatar">
            <% } else { %>
              <i class="fa-solid fa-user"></i>
            <% } %>
          </div>
          <label for="avatarFileQuick" class="profile-avatar-edit" title="Change photo">
            <i class="fa-solid fa-pen"></i>
          </label>
        </div>

        <div class="profile-name"><%= currentUser.name %></div>
        <div style="margin: 0.4rem 0 0.75rem;">
          <span class="profile-role-badge"><i class="fa-solid fa-user"></i> Renter</span>
          <% if (currentUser.aadhaarVerified) { %>
            <span class="badge badge-success" style="margin-left: 4px;"><i class="fa-solid fa-check"></i> Aadhaar Verified</span>
          <% } %>
        </div>
        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
          <i class="fa-solid fa-envelope"></i> <%= currentUser.email %>
        </p>
        <% if (currentUser.phone) { %>
        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
          <i class="fa-solid fa-phone"></i> <%= currentUser.phone %>
        </p>
        <% } %>
        <% if (currentUser.address) { %>
        <p style="font-size: 0.85rem; color: var(--text-secondary);">
          <i class="fa-solid fa-location-dot"></i> <%= currentUser.address %>
        </p>
        <% } %>

        <div class="profile-stat-row">
          <div class="profile-stat">
            <div class="profile-stat-value">0</div>
            <div class="profile-stat-label">Bookings</div>
          </div>
          <div class="profile-stat">
            <div class="profile-stat-value">
              <% if (currentUser.aadhaarVerified) { %>
                <i class="fa-solid fa-circle-check" style="color: var(--success); font-size: 1.5rem;"></i>
              <% } else { %>
                <i class="fa-solid fa-circle-xmark" style="color: var(--danger); font-size: 1.5rem;"></i>
              <% } %>
            </div>
            <div class="profile-stat-label">KYC</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Edit Forms -->
    <div>

      <!-- Basic Info Form -->
      <div class="profile-form-card">
        <div class="profile-section-title">
          <i class="fa-solid fa-pen-to-square" style="color: var(--primary);"></i> Personal Information
        </div>

        <form action="/user/profile" method="POST" enctype="multipart/form-data">
          <input type="file" name="avatar" id="avatarFileQuick" style="display:none;" accept="image/*"
            onchange="this.form.submit()">

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" name="name" id="name" class="form-control" value="<%= currentUser.name %>" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" name="phone" id="phone" class="form-control" value="<%= currentUser.phone || '' %>">
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 1.5rem; position: relative;">
            <label for="address">
              <i class="fa-solid fa-location-dot" style="color: var(--primary);"></i> Your Address
              <span style="font-size:0.78rem; font-weight:400; color: var(--text-hint);">(visible to sellers & admins)</span>
            </label>
            <div style="display: flex; gap: 8px; position: relative;">
              <div style="flex: 1; position: relative;">
                <input type="text" name="address" id="address" class="form-control"
                  value="<%= currentUser.address || '' %>"
                  placeholder="Start typing your address... e.g. Andheri West, Mumbai"
                  autocomplete="off" style="padding-right: 36px;">
                <i class="fa-solid fa-magnifying-glass" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--text-hint); pointer-events:none;"></i>
                <!-- Autocomplete dropdown -->
                <div id="address-suggestions" style="
                  display:none; position:absolute; top:100%; left:0; right:0;
                  background:#fff; border:1px solid var(--border); border-top:none;
                  border-radius:0 0 var(--radius-md) var(--radius-md);
                  box-shadow:var(--shadow-md); z-index:9999; max-height:200px; overflow-y:auto;">
                </div>
              </div>
              <button type="button" id="use-my-loc-btn" class="btn btn-outline" style="flex-shrink:0; padding:10px 14px;" title="Use my current location">
                <i class="fa-solid fa-location-crosshairs"></i> My Location
              </button>
            </div>
            <span class="form-hint">This helps sellers coordinate item pickup/delivery.</span>
          </div>

          <!-- Map -->
          <div style="height:250px; margin-bottom:1.5rem; border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden; position:relative;">
            <div id="location-picker-map" style="width:100%; height:100%;"></div>
            <div style="position:absolute; bottom:8px; right:8px; background:rgba(255,255,255,0.9); border-radius:6px; padding:4px 8px; font-size:0.72rem; color:var(--text-secondary); pointer-events:none; box-shadow:var(--shadow-sm); z-index: 1000;">
              <i class="fa-solid fa-hand-pointer"></i> Click map or drag pin to set location
            </div>
          </div>

          <!-- Hidden coordinates -->
          <input type="hidden" name="lng" id="lng" value="<%= currentUser.location && currentUser.location.coordinates ? currentUser.location.coordinates[0] : '' %>">
          <input type="hidden" name="lat" id="lat" value="<%= currentUser.location && currentUser.location.coordinates ? currentUser.location.coordinates[1] : '' %>">

          <button type="submit" class="btn btn-primary" id="saveProfileBtn">
            <i class="fa-solid fa-floppy-disk"></i> Save Changes
          </button>
        </form>
      </div>

      <!-- Aadhaar Verification Card -->
      <div class="profile-form-card">
        <div class="profile-section-title">
          <i class="fa-solid fa-id-card" style="color: var(--accent);"></i> Aadhaar Verification
        </div>

        <!-- Current Aadhaar Status Card -->
        <% if (currentUser.aadhaarNumber || currentUser.aadhaarDoc && currentUser.aadhaarDoc.url) { %>
          <div class="aadhaar-card" style="margin-bottom: 1.5rem;">
            <div style="font-size: 0.75rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.08em;">Government of India</div>
            <div style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.25rem;">Aadhaar</div>
            <div class="aadhaar-number-display">
              <% if (currentUser.aadhaarNumber) { %>
                XXXX XXXX <%= currentUser.aadhaarNumber.slice(-4) %>
              <% } else { %>
                XXXX XXXX XXXX
              <% } %>
            </div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.75rem;">
              <span style="font-size:0.8rem; opacity:0.7;"><%= currentUser.name %></span>
              <% if (currentUser.aadhaarVerified) { %>
                <span class="aadhaar-status-badge verified"><i class="fa-solid fa-circle-check"></i> Verified</span>
              <% } else if (currentUser.aadhaarDoc && currentUser.aadhaarDoc.url) { %>
                <span class="aadhaar-status-badge pending"><i class="fa-solid fa-clock"></i> Pending Review</span>
              <% } else { %>
                <span class="aadhaar-status-badge not-uploaded"><i class="fa-solid fa-circle-exclamation"></i> Not Uploaded</span>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if (!currentUser.aadhaarVerified) { %>
          <form action="/user/aadhaar" method="POST" enctype="multipart/form-data">
            <div class="form-group">
              <label for="aadhaarNumber">Aadhaar Number (12 digits)</label>
              <input type="text" name="aadhaarNumber" id="aadhaarNumber" class="form-control"
                value="<%= currentUser.aadhaarNumber ? currentUser.aadhaarNumber.replace(/(\d{4})(\d{4})(\d{4})/, '$1 $2 $3') : '' %>"
                placeholder="1234 5678 9012" maxlength="14"
                oninput="formatAadhaar(this)">
            </div>
            <div class="form-group">
              <label>Aadhaar Card Photo</label>
              <div class="file-upload-area" onclick="document.getElementById('aadhaarFile').click()">
                <input type="file" name="aadhaar" id="aadhaarFile" accept="image/*,application/pdf"
                  onchange="showFileName(this, 'aadhaarFileNameDisplay')">
                <% if (currentUser.aadhaarDoc && currentUser.aadhaarDoc.url) { %>
                  <div class="file-upload-icon"><i class="fa-solid fa-check-circle" style="color: var(--success);"></i></div>
                  <div class="file-upload-text">Aadhaar uploaded — click to replace</div>
                <% } else { %>
                  <div class="file-upload-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                  <div class="file-upload-text" id="aadhaarFileNameDisplay">
                    Click to upload Aadhaar card image<br>
                    <small style="color:var(--text-hint);">JPG, PNG, or PDF — max 5MB</small>
                  </div>
                <% } %>
              </div>
            </div>
            <button type="submit" class="btn btn-accent" id="submitAadhaarBtn">
              <i class="fa-solid fa-upload"></i> Submit for Verification
            </button>
          </form>
        <% } else { %>
          <div style="display: flex; align-items: center; gap: 12px; padding: 1rem; background: #dcfce7; border-radius: var(--radius-md); border: 1px solid #86efac;">
            <i class="fa-solid fa-circle-check" style="color: var(--success); font-size: 1.5rem;"></i>
            <div>
              <strong style="color: #166534;">Aadhaar Verified</strong>
              <p style="font-size: 0.85rem; color: #166534; margin: 0;">Your identity has been confirmed by our team.</p>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<script>
  function formatAadhaar(input) {
    let v = input.value.replace(/\D/g, '').substring(0, 12);
    input.value = v.replace(/(\d{4})(?=\d)/g, '$1 ').trim();
  }
  function showFileName(input, targetId) {
    if (input.files && input.files[0]) {
      const el = document.getElementById(targetId);
      if (el) el.innerHTML = '<i class="fa-solid fa-check-circle" style="color:var(--success);"></i> ' + input.files[0].name;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const addressInput = document.getElementById('address');
    const suggestionBox = document.getElementById('address-suggestions');
    const latInput = document.getElementById('lat');
    const lngInput = document.getElementById('lng');
    const useMyLocBtn = document.getElementById('use-my-loc-btn');

    // ── Leaflet map setup ──
    const savedLat = parseFloat(latInput.value) || 19.0760;
    const savedLng = parseFloat(lngInput.value) || 72.8777;

    const map = L.map('location-picker-map').setView([savedLat, savedLng], 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a> contributors'
    }).addTo(map);

    const marker = L.marker([savedLat, savedLng], { draggable: true }).addTo(map);

    function setCoords(lat, lng) {
      latInput.value = lat;
      lngInput.value = lng;
    }

    // ── Reverse geocode (pin → address) ──
    async function reverseGeocode(lat, lng) {
      try {
        const res = await fetch(
          `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`,
          { headers: { 'Accept-Language': 'en', 'User-Agent': 'RentItApp/1.0' } }
        );
        const data = await res.json();
        if (data && data.display_name) {
          addressInput.value = data.display_name;
        }
      } catch (e) { /* silent */ }
    }

    marker.on('dragend', (e) => {
      const { lat, lng } = marker.getLatLng();
      setCoords(lat, lng);
      reverseGeocode(lat, lng);
    });

    map.on('click', (e) => {
      marker.setLatLng(e.latlng);
      setCoords(e.latlng.lat, e.latlng.lng);
      reverseGeocode(e.latlng.lat, e.latlng.lng);
    });

    // ── Address autocomplete (forward geocode) ──
    let searchTimer = null;

    addressInput.addEventListener('input', () => {
      clearTimeout(searchTimer);
      const q = addressInput.value.trim();
      if (q.length < 3) {
        suggestionBox.style.display = 'none';
        return;
      }
      searchTimer = setTimeout(() => searchAddress(q), 350);
    });

    async function searchAddress(query) {
      try {
        const res = await fetch(
          `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5&countrycodes=in`,
          { headers: { 'Accept-Language': 'en', 'User-Agent': 'RentItApp/1.0' } }
        );
        const data = await res.json();
        renderSuggestions(data);
      } catch (e) {
        suggestionBox.style.display = 'none';
      }
    }

    function renderSuggestions(list) {
      suggestionBox.innerHTML = '';
      if (!list || list.length === 0) {
        suggestionBox.style.display = 'none';
        return;
      }

      list.forEach(item => {
        const div = document.createElement('div');
        div.style.padding = '10px 12px';
        div.style.cursor = 'pointer';
        div.style.borderBottom = '1px solid var(--border)';
        div.style.fontSize = '0.88rem';
        div.innerHTML = `<i class="fa-solid fa-location-dot" style="color:var(--primary); margin-right:8px;"></i> ${item.display_name}`;
        
        div.addEventListener('mouseover', () => {
          div.style.background = '#f8fafc';
        });
        div.addEventListener('mouseout', () => {
          div.style.background = 'transparent';
        });

        div.addEventListener('click', () => {
          const lat = parseFloat(item.lat);
          const lon = parseFloat(item.lon);
          addressInput.value = item.display_name;
          setCoords(lat, lon);
          marker.setLatLng([lat, lon]);
          map.setView([lat, lon], 15);
          suggestionBox.style.display = 'none';
        });
        suggestionBox.appendChild(div);
      });

      suggestionBox.style.display = 'block';
    }

    // Hide dropdown on click outside
    document.addEventListener('click', (e) => {
      if (!addressInput.contains(e.target) && !suggestionBox.contains(e.target)) {
        suggestionBox.style.display = 'none';
      }
    });

    // ── My Location ──
    useMyLocBtn.addEventListener('click', () => {
      if (!navigator.geolocation) {
        alert('Geolocation is not supported by your browser.');
        return;
      }
      useMyLocBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      useMyLocBtn.disabled = true;

      navigator.geolocation.getCurrentPosition((pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;
        setCoords(lat, lng);
        marker.setLatLng([lat, lng]);
        map.setView([lat, lng], 15);
        reverseGeocode(lat, lng);
        
        useMyLocBtn.innerHTML = '<i class="fa-solid fa-location-crosshairs"></i> My Location';
        useMyLocBtn.disabled = false;
      }, (err) => {
        alert('Could not get your location: ' + err.message);
        useMyLocBtn.innerHTML = '<i class="fa-solid fa-location-crosshairs"></i> My Location';
        useMyLocBtn.disabled = false;
      }, { enableHighAccuracy: true });
    });
  });
</script>

<%- include('../layouts/footer') %>
