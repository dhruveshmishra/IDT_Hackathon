    </div>
  </div>

  <!-- Features Scrolling Row -->
  <div class="scroll-wrapper">
    <div class="features-section">
      <div class="feature-item">
        <div class="feature-icon-wrapper"><i class="fa-solid fa-boxes-stacked"></i></div>
        <div class="feature-text">Free Up Space</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon-wrapper"><i class="fa-solid fa-indian-rupee-sign"></i></div>
        <div class="feature-text">Earn Extra Income</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon-wrapper"><i class="fa-solid fa-calendar-check"></i></div>
        <div class="feature-text">Flexible Rental Terms</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon-wrapper"><i class="fa-solid fa-users"></i></div>
        <div class="feature-text">Wide Audience Reach</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon-wrapper"><i class="fa-solid fa-leaf"></i></div>
        <div class="feature-text">Sustainable Sharing</div>
      </div>
    </div>
  </div>

  <!-- Product Categories Section -->
  <div>
