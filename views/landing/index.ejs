<%- include('../layouts/main') %>

<!-- Custom Styling for Premium Rentit4me Theme -->
<style>
  /* Hero Carousel / Peek Banner Slider */
  .peek-banner-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    border-radius: var(--radius-lg);
    margin-bottom: 2.5rem;
    box-shadow: var(--shadow-md);
    background: #f8fafc;
  }
  .peek-banner-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .peek-banner-slide {
    min-width: 100%;
    position: relative;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    background: #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .peek-banner-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .banner-overlay-content {
    position: absolute;
    left: 8%;
    top: 50%;
    transform: translateY(-50%);
    color: #fff;
    max-width: 450px;
    z-index: 10;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
  .banner-overlay-content h1 {
    color: #fff;
    font-size: 2.8rem;
    font-family: var(--font-display);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .banner-overlay-content p {
    font-size: 1.1rem;
    opacity: 0.95;
    margin-bottom: 1.5rem;
  }

  /* Horizontal Scrolling Features Section */
  .scroll-wrapper {
    overflow-x: auto;
    white-space: nowrap;
    padding: 1.5rem 0.5rem;
    margin-bottom: 3.5rem;
    border-bottom: 1px solid var(--border);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .scroll-wrapper::-webkit-scrollbar {
    height: 5px;
  }
  .scroll-wrapper::-webkit-scrollbar-track {
    background: transparent;
  }
  .scroll-wrapper::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 10px;
  }
  .scroll-wrapper::-webkit-scrollbar-thumb:hover {
    background: var(--text-hint);
  }
  .features-section {
    display: inline-flex;
    gap: 1.5rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    min-width: 250px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .feature-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .feature-icon-wrapper {
    width: 48px;
    height: 48px;
    background: var(--primary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    font-size: 1.35rem;
    flex-shrink: 0;
  }
  .feature-text {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  /* Modern Category Sections */
  .section-indicator {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .indicator-bar {
    width: 60px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .indicator-inner {
    width: 50%;
    height: 100%;
    background: var(--primary);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin-bottom: 2rem;
    font-weight: 700;
  }
  .title-highlight {
    background: linear-gradient(to right, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1.25rem;
    margin-bottom: 4rem;
  }
  .category-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem 1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    transition: all 0.25s ease;
    cursor: pointer;
  }
  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }
  .category-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    color: var(--primary);
    transition: background 0.2s;
  }
  .category-card:hover .category-icon {
    background: var(--primary-light);
    color: var(--primary-dark);
  }
  .category-label {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.925rem;
  }

  /* Two Column Listing Callouts */
  .callout-banners {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 4.5rem;
  }
  .callout-card {
    border-radius: var(--radius-lg);
    padding: 3rem 2.5rem;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 280px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .callout-card.product {
    background: linear-gradient(135deg, #0e57da 0%, #1e40af 100%);
  }
  .callout-card.service {
    background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
  }
  .callout-card h3 {
    color: #fff;
    font-size: 2rem;
    font-family: var(--font-display);
    margin-bottom: 0.5rem;
    z-index: 2;
  }
  .callout-card p {
    font-size: 1.05rem;
    opacity: 0.9;
    max-width: 320px;
    margin-bottom: 2rem;
    z-index: 2;
  }

  /* FAQ Accordion */
  .faq-section {
    display: flex;
    gap: 3rem;
    margin-bottom: 5rem;
    flex-wrap: wrap;
  }
  .faq-left {
    flex: 1;
    min-width: 280px;
  }
  .faq-left h2 {
    font-size: 2.2rem;
    line-height: 1.25;
    font-family: var(--font-display);
  }
  .faq-right {
    flex: 2;
    min-width: 320px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s;
  }
  .faq-item:hover {
    border-color: var(--primary);
  }
  .faq-question {
    padding: 1.25rem 1.5rem;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
    color: var(--text-primary);
  }
  .faq-toggle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 400;
  }
  .faq-answer {
    display: none;
    padding: 0 1.5rem 1.5rem 1.5rem;
    color: var(--text-secondary);
    font-size: 0.925rem;
    line-height: 1.6;
    border-top: 1px solid var(--border);
  }
  .faq-item.active .faq-answer {
    display: block;
  }

  @media (max-width: 768px) {
    .callout-banners {
      grid-template-columns: 1fr;
    }
    .peek-banner-slide {
      aspect-ratio: 16 / 9;
    }
    .banner-overlay-content h1 {
      font-size: 1.8rem;
    }
    .scroll-wrapper {
      padding: 1rem 0.25rem 1.5rem 0.25rem;
      margin-bottom: 2.5rem;
    }
    .features-section {
      gap: 1rem;
    }
    .feature-item {
      min-width: 220px;
      padding: 0.85rem 1.25rem;
    }
  }
</style>

<div class="container" style="margin-top: 2rem;">

  <!-- Hero Carousel Slider (Inspired by Rentit4me) -->
