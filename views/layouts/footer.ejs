          <div style="margin-bottom: 1.25rem; text-align: left;">
            <label for="p2p-email" class="p2p-input-label">Email Address</label>
            <input type="email" name="email" id="p2p-email" class="form-control" placeholder="name@example.com" required style="border-radius: 10px; height: 48px; border: 1px solid #cbd5e1; padding: 0 16px; width: 100%; outline: none;">
          </div>

          <div style="margin-bottom: 1.5rem; text-align: left;">
            <label for="p2p-password" class="p2p-input-label">Password</label>
            <input type="password" name="password" id="p2p-password" class="form-control" placeholder="Enter your password" required style="border-radius: 10px; height: 48px; border: 1px solid #cbd5e1; padding: 0 16px; width: 100%; outline: none;">
          </div>

          <button type="submit" class="p2p-continue-btn" style="margin-bottom: 1.5rem;">Sign In</button>
        </form>

        <p style="font-size: 0.9rem; color: #64748b; margin: 0;">
          New to RentIt? <a href="/auth/signup" class="orange-link">Create an account</a>
        </p>
      </div>
    </div>
  </div>
</div>

<style>
/* CSS Styles for Split Login/Signup Modal */
.p2p-modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(5px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  transition: opacity 0.3s ease;
}

.p2p-modal-container {
  background: #ffffff;
  border-radius: 24px;
  width: 850px;
  max-width: 90%;
  height: 520px;
  max-height: 90vh;
  position: relative;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  animation: modalPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalPop {
  0% { transform: scale(0.9); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.p2p-modal-close-btn {
  position: absolute;
  top: 15px;
  right: 20px;
  background: transparent;
  border: none;
  font-size: 2.25rem;
  color: #64748b;
  cursor: pointer;
  z-index: 10;
  line-height: 1;
  transition: color 0.2s;
}

.p2p-modal-close-btn:hover {
  color: #0f172a;
}

.p2p-modal-split {
  display: flex;
  height: 100%;
  width: 100%;
}

.p2p-modal-left {
  width: 48%;
  height: 100%;
  overflow: hidden;
  background: #f8fafc;
}

.p2p-modal-left img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.p2p-modal-right {
  width: 52%;
  padding: 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
}

.p2p-modal-title {
  font-family: var(--font-display), sans-serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 1.5rem;
  text-align: center;
}

.p2p-social-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-bottom: 1.5rem;
}

.p2p-social-btn {
  flex: 1;
  max-width: 120px;
  height: 48px;
  border: 1px solid #e2e8f0;
  background: #fff;
  border-radius: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.2s, background 0.2s;
}

.p2p-social-btn:hover {
  border-color: #cbd5e1;
  background: #f8fafc;
}

.p2p-social-btn img {
  width: 20px;
  height: 20px;
}

.p2p-social-btn i {
  font-size: 1.25rem;
}

.p2p-divider {
  display: flex;
  align-items: center;
  margin: 1rem 0 1.5rem 0;
  color: #64748b;
  font-size: 0.85rem;
  font-weight: 500;
}

.p2p-divider::before,
.p2p-divider::after {
  content: "";
  flex: 1;
  border-bottom: 1px solid #e2e8f0;
}

.p2p-divider span {
  padding: 0 10px;
}

.p2p-input-label {
  display: block;
  font-size: 0.95rem;
  font-weight: 700;
  color: #0f172a;
  text-align: left;
  margin-bottom: 8px;
}

.p2p-phone-input-group {
  display: flex;
  border: 1px solid #cbd5e1;
  border-radius: 10px;
  overflow: hidden;
  height: 48px;
  transition: border-color 0.2s;
}

.p2p-phone-input-group:focus-within {
  border-color: #ff5a00;
}

.p2p-country-select {
  background: #f8fafc;
  border-right: 1px solid #e2e8f0;
  padding: 0 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  color: #0f172a;
  font-weight: 600;
  font-size: 0.9rem;
  user-select: none;
}

.p2p-country-select i {
  font-size: 0.75rem;
  color: #64748b;
}

.p2p-phone-control {
  flex: 1;
  border: none;
  padding: 0 16px;
  font-size: 0.925rem;
  color: #0f172a;
  outline: none;
}

.p2p-checkbox-label {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  cursor: pointer;
  user-select: none;
}

.p2p-checkbox-label input[type="checkbox"] {
  margin-top: 3px;
  accent-color: #ff5a00;
}

.p2p-checkbox-label .checkbox-text {
  font-size: 0.825rem;
  color: #64748b;
  line-height: 1.4;
}

.orange-link {
  color: #ff5a00;
  text-decoration: none;
  font-weight: 600;
}

.orange-link:hover {
  text-decoration: underline;
}

.p2p-continue-btn {
  width: 100%;
  height: 48px;
  background-color: #ff5a00;
  color: #ffffff;
  border: none;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: background-color 0.2s;
}

.p2p-continue-btn:hover {
  background-color: #e04f00;
}

/* Responsive modal rules */
@media (max-width: 768px) {
  .p2p-modal-container {
    width: 420px;
    height: auto;
    max-height: 90vh;
  }
  .p2p-modal-split {
    flex-direction: column;
  }
  .p2p-modal-left {
    display: none;
  }
  .p2p-modal-right {
    width: 100%;
    padding: 2.5rem 1.5rem;
  }
}
</style>

<script>
function showP2PLoginModal() {
  document.getElementById('p2p-login-modal').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeP2PLoginModal() {
  document.getElementById('p2p-login-modal').style.display = 'none';
  document.body.style.overflow = 'auto';
}

// Close modal when clicking outside the container
document.getElementById('p2p-login-modal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeP2PLoginModal();
  }
});
</script>
<% } %>

          </body>

          </html>