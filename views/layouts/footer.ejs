      <% if (currentUser && currentUser.role==='user' ) { %>
        <!-- Chatbot Toggle Button -->
        <div id="ai-chatbot-toggle"
          style="position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: var(--primary); color: #fff; width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-md); cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); hover: scale(1.05);">
          <i class="fa-solid fa-robot" style="font-size: 1.5rem;"></i>
        </div>

        <!-- Chatbot Window -->
        <div id="ai-chatbot-window"
          style="display: none; position: fixed; bottom: 96px; right: 24px; width: 360px; height: 480px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); z-index: 9999; overflow: hidden; flex-direction: column;">
          <!-- Header -->
          <div
            style="background: var(--primary); color: #fff; padding: 16px; display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <i class="fa-solid fa-robot" style="font-size: 1.2rem;"></i>
              <span style="font-weight: 700; font-family: var(--font-display);">RentIt Assistant</span>
            </div>
            <button id="ai-chatbot-close"
              style="background: transparent; border: none; color: #fff; cursor: pointer; font-size: 1rem;"><i
                class="fa-solid fa-xmark"></i></button>
          </div>
          <!-- Messages body -->
          <div id="ai-chatbot-messages"
            style="flex: 1; padding: 16px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; background: #f8fafc;">
            <div
              style="align-self: flex-start; background: #fff; border: 1px solid var(--border); padding: 10px 14px; border-radius: var(--radius-md) var(--radius-md) var(--radius-md) 0; font-size: 0.85rem; max-width: 80%; line-height: 1.45; color: var(--text-primary);">
              Hello! 👋 I am your RentIt Assistant. Ask me about items listed nearby, how hourly/daily booking works, or
              general user features!
            </div>
          </div>
          <!-- Input Area -->
          <form id="ai-chatbot-form"
            style="border-top: 1px solid var(--border); display: flex; padding: 8px; gap: 8px; background: var(--surface);">
            <input type="text" id="ai-chatbot-input" placeholder="Ask about items or working..."
              style="flex: 1; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 8px 12px; font-size: 0.85rem;"
              autocomplete="off" required>
            <button type="submit"
              style="background: var(--primary); color: #fff; border: none; border-radius: var(--radius-md); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer;"><i
                class="fa-solid fa-paper-plane"></i></button>
          </form>
        </div>

        <script>
          document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('ai-chatbot-toggle');
            const chatWindow = document.getElementById('ai-chatbot-window');
            const closeBtn = document.getElementById('ai-chatbot-close');
            const chatForm = document.getElementById('ai-chatbot-form');
            const chatInput = document.getElementById('ai-chatbot-input');
            const messagesDiv = document.getElementById('ai-chatbot-messages');

            let chatHistory = [];

            toggleBtn.addEventListener('click', () => {
              if (chatWindow.style.display === 'none' || !chatWindow.style.display) {
                chatWindow.style.display = 'flex';
              } else {
                chatWindow.style.display = 'none';
              }
            });

            closeBtn.addEventListener('click', () => {
              chatWindow.style.display = 'none';
            });

            chatForm.addEventListener('submit', async (e) => {
              e.preventDefault();
              const text = chatInput.value.trim();
              if (!text) return;

              // Add User Message bubble
              appendMessageBubble(text, 'user');
              chatInput.value = '';

              // Add temporary loader
              const loaderId = 'ai-loader-' + Date.now();
              appendLoaderBubble(loaderId);

              // Build item contexts from the page if available
              let pageItems = [];
              if (window.itemsData) {
                pageItems = window.itemsData;
              }

              try {
                const res = await fetch('/ai/chatbot', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    message: text,
                    items: pageItems,
                    history: chatHistory
                  })
                });
                const data = await res.json();
                document.getElementById(loaderId).remove();

                if (data.success && data.reply) {
                  appendMessageBubble(data.reply, 'bot');
                  chatHistory.push({ role: 'user', text });
                  chatHistory.push({ role: 'bot', text: data.reply });
                  if (chatHistory.length > 10) chatHistory = chatHistory.slice(-10); // keep history short
                } else {
                  appendMessageBubble("Sorry, I encountered an issue. Please try again.", 'bot');
                }
              } catch (err) {
                document.getElementById(loaderId).remove();
                appendMessageBubble("Sorry, I'm currently unable to connect.", 'bot');
              }
            });

            function appendMessageBubble(messageText, sender) {
              const bubble = document.createElement('div');
              bubble.style.fontSize = '0.85rem';
              bubble.style.maxWidth = '80%';
              bubble.style.padding = '10px 14px';
              bubble.style.lineHeight = '1.45';

              if (sender === 'user') {
                bubble.style.alignSelf = 'flex-end';
                bubble.style.background = 'var(--primary)';
                bubble.style.color = '#fff';
                bubble.style.borderRadius = 'var(--radius-md) var(--radius-md) 0 var(--radius-md)';
              } else {
                bubble.style.alignSelf = 'flex-start';
                bubble.style.background = '#fff';
                bubble.style.border = '1px solid var(--border)';
                bubble.style.color = 'var(--text-primary)';
                bubble.style.borderRadius = 'var(--radius-md) var(--radius-md) var(--radius-md) 0';
              }

              bubble.textContent = messageText;
              messagesDiv.appendChild(bubble);
              messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            function appendLoaderBubble(id) {
              const bubble = document.createElement('div');
              bubble.id = id;
              bubble.style.fontSize = '0.85rem';
              bubble.style.maxWidth = '80%';
              bubble.style.padding = '10px 14px';
              bubble.style.alignSelf = 'flex-start';
              bubble.style.background = '#fff';
              bubble.style.border = '1px solid var(--border)';
              bubble.style.color = 'var(--text-secondary)';
              bubble.style.borderRadius = 'var(--radius-md) var(--radius-md) var(--radius-md) 0';
              bubble.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Typings...';

              messagesDiv.appendChild(bubble);
              messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }
          });
        </script>
        <% } %>

<% if (!currentUser) { %>
<!-- Split Login/Signup Modal (Inspired by Rentit4me) -->
<div id="p2p-login-modal" class="p2p-modal-backdrop" style="display: none;">
