<%- include('../layouts/main') %>

<div class="container" style="max-width: 1100px;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
    <h2 style="font-family: var(--font-display);"><i class="fa-solid fa-receipt"></i> Platform Bookings Log</h2>
    <a href="/admin/dashboard" class="btn btn-outline">&larr; Back to Dashboard</a>
  </div>

  <!-- Selected Seller View Header -->
  <% if (selectedSellerId) { %>
    <% 
      const activeSeller = sellers.find(s => String(s._id) === selectedSellerId);
    %>
    <% if (activeSeller) { %>
      <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem; box-shadow: var(--shadow-sm);">
        <div style="display: flex; gap: 1.25rem; align-items: center;">
          <% if (activeSeller.avatar && activeSeller.avatar.url) { %>
            <img src="<%= activeSeller.avatar.url %>" style="width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary);">
          <% } else { %>
            <div style="width: 64px; height: 64px; border-radius: 50%; background-color:#cbd5e1; display:flex; align-items:center; justify-content:center; font-weight:700; font-size: 1.5rem; border: 2px solid var(--primary); color: #475569;"><%= activeSeller.name[0] %></div>
          <% } %>
          <div>
            <span style="font-size: 0.72rem; text-transform: uppercase; font-weight: 700; color: var(--primary); letter-spacing: 0.5px;">Currently Viewing History for</span>
            <h3 style="margin: 2px 0; font-family: var(--font-display); font-size: 1.35rem;"><%= activeSeller.name %></h3>
            <p style="margin: 0; font-size: 0.88rem; color: var(--text-secondary);"><i class="fa-regular fa-envelope"></i> <%= activeSeller.email %></p>
          </div>
        </div>
        <div>
          <a href="/admin/bookings" class="btn btn-outline" style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none; border-color: var(--border); background: #ffffff;">
            <i class="fa-solid fa-arrow-left"></i> Back to All Sellers
          </a>
        </div>
      </div>
    <% } %>

    <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
        <thead>
          <tr style="border-bottom: 2px solid var(--border); color: var(--text-secondary); font-weight: 600;">
            <th style="padding: 10px 8px;">Booking ID</th>
            <th style="padding: 10px 8px;">Item Title</th>
            <th style="padding: 10px 8px;">Renter / Seller</th>
            <th style="padding: 10px 8px;">Rental Dates</th>
            <th style="padding: 10px 8px;">Status</th>
            <th style="padding: 10px 8px;">Payment</th>
            <th style="padding: 10px 8px;">GTV</th>
          </tr>
        </thead>
        <tbody>
          <% if (bookings.length === 0) { %>
            <tr>
              <td colspan="7" style="padding: 20px; text-align: center; color: var(--text-hint);">No bookings matching this criteria.</td>
            </tr>
          <% } else { %>
            <% bookings.forEach(booking => { %>
              <tr style="border-bottom: 1px solid var(--border);">
                <td style="padding: 12px 8px; font-family: monospace; font-size: 0.8rem;"><%= booking._id %></td>
                <td style="padding: 12px 8px; font-weight: 600;"><%= booking.item ? booking.item.title : 'Deleted Item' %></td>
                <td style="padding: 12px 8px; font-size: 0.85rem;">
                  R: <%= booking.renter ? booking.renter.name : 'N/A' %><br/>
                  S: <% if (booking.seller) { %>
                    <a href="/admin/bookings?sellerId=<%= booking.seller._id %>" style="color: var(--primary); font-weight: 600; text-decoration: underline;" title="View all bookings for this seller"><%= booking.seller.name %></a>
                  <% } else { %>
                    N/A
                  <% } %>
                </td>
                <td style="padding: 12px 8px; font-size: 0.85rem; color: var(--text-secondary);">
                  <%= new Date(booking.startDate).toLocaleDateString() %> - <%= new Date(booking.endDate).toLocaleDateString() %>
                </td>
                <td style="padding: 12px 8px;">
                  <span style="font-size:0.75rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;
                    <%= booking.status === 'confirmed' ? 'background-color:#dcfce7; color:#15803d;' : '' %>
                    <%= booking.status === 'pending' ? 'background-color:#fef3c7; color:#b45309;' : '' %>
                    <%= booking.status === 'active' ? 'background-color:#eff6ff; color:#2563eb;' : '' %>
                    <%= booking.status === 'completed' ? 'background-color:#f1f5f9; color:#64748b;' : '' %>
                    <%= booking.status === 'cancelled' ? 'background-color:#fee2e2; color:#dc2626;' : '' %>
                  ">
                    <%= booking.status %>
                  </span>
                </td>
                <td style="padding: 12px 8px;">
                  <span style="font-size:0.75rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;
                    <%= booking.payment.status === 'paid' ? 'background-color:#dcfce7; color:#15803d;' : 'background-color:#fee2e2; color:#dc2626;' %>
                  ">
                    <%= booking.payment.status %>
                  </span>
                </td>
                <td style="padding: 12px 8px; font-weight: 700;">₹<%= booking.totalAmount %></td>
              </tr>
              <% if (booking.paymentScreenshot || (booking.dispute && (booking.dispute.beforeImage || booking.dispute.afterImage || booking.dispute.aiAnalysis))) { %>
                <tr style="background-color: #f8fafc; border-bottom: 1px solid var(--border);">
                  <td colspan="7" style="padding: 12px 16px;">
                    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
                      
                      <!-- P2P Payment Screenshot -->
                      <% if (booking.paymentScreenshot) { %>
                        <div style="flex: 1; min-width: 240px; border: 1px solid var(--border); border-radius: 6px; padding: 12px; background: #ffffff;">
                          <h5 style="margin: 0 0 8px; font-size: 0.82rem; font-family: var(--font-display); color: var(--text-primary); display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-receipt" style="color: var(--primary);"></i> P2P Payment Reference
                          </h5>
                          <div style="text-align: center;">
                            <a href="<%= booking.paymentScreenshot %>" target="_blank">
                              <img src="<%= booking.paymentScreenshot %>" style="max-height: 120px; max-width: 100%; object-fit: contain; border-radius: 4px; border: 1px solid var(--border);">
                            </a>
                          </div>
                        </div>
                      <% } %>

                      <!-- AI Handover / Return Condition -->
                      <% if (booking.dispute && (booking.dispute.beforeImage || booking.dispute.afterImage)) { %>
                        <div style="flex: 2; min-width: 300px; border: 1px solid var(--border); border-radius: 6px; padding: 12px; background: #ffffff; display: flex; flex-direction: column; gap: 10px;">
                          <h5 style="margin: 0; font-size: 0.82rem; font-family: var(--font-display); color: var(--text-primary); display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-camera" style="color: var(--accent);"></i> Handover & Return Verification
                          </h5>
                          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <% if (booking.dispute.beforeImage) { %>
                              <div>
                                <span style="font-size: 0.68rem; color: var(--text-secondary); font-weight: 700; text-transform: uppercase; display: block; margin-bottom: 4px;">Handover State</span>
                                <a href="<%= booking.dispute.beforeImage %>" target="_blank">
                                  <img src="<%= booking.dispute.beforeImage %>" style="max-height: 100px; width: 100%; object-fit: contain; border-radius: 4px; border: 1px solid var(--border); background: #f8fafc;">
                                </a>
                              </div>
                            <% } %>
                            <% if (booking.dispute.afterImage) { %>
                              <div>
                                <span style="font-size: 0.68rem; color: var(--text-secondary); font-weight: 700; text-transform: uppercase; display: block; margin-bottom: 4px;">Return State</span>
                                <a href="<%= booking.dispute.afterImage %>" target="_blank">
                                  <img src="<%= booking.dispute.afterImage %>" style="max-height: 100px; width: 100%; object-fit: contain; border-radius: 4px; border: 1px solid var(--border); background: #f8fafc;">
                                </a>
                              </div>
                            <% } %>
                          </div>
                        </div>
                      <% } %>

                      <!-- Gemini AI Damage Assessment Details -->
                      <% if (booking.dispute && booking.dispute.aiAnalysis) { %>
                        <div style="flex: 2; min-width: 320px; border: 1px solid #fde68a; border-radius: 6px; padding: 12px; background: #fffdf5;">
                          <h5 style="margin: 0 0 6px; font-size: 0.82rem; font-family: var(--font-display); color: #b45309; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> Gemini AI Assessment
                          </h5>
                          <p style="margin: 0 0 8px; font-size: 0.78rem; line-height: 1.4; color: #475569; white-space: pre-line;"><%= booking.dispute.aiAnalysis %></p>
                          
                          <% 
                            let locMatch = (booking.dispute.aiAnalysis || '').match(/Detected Location:\s*([A-Z-]+)/i);
                            let detectedLoc = locMatch ? locMatch[1] : 'NONE';
                          %>
                          <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; border-top: 1px dashed #fcd34d; padding-top: 6px; margin-top: 6px;">
                            <span style="font-weight: 700; color: #475569;">Detected Location:</span>
                            <span style="background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; font-size: 0.68rem; font-weight: 700; padding: 1px 8px; border-radius: 99px; text-transform: uppercase;">
                              <%= detectedLoc %>
                            </span>
                          </div>
                          <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; margin-top: 4px;">
                            <span style="font-weight: 700; color: #475569;">Security Deduction:</span>
                            <span style="color: var(--danger); font-weight: 700;">₹0 (Direct P2P negotiation)</span>
                          </div>
                        </div>
                      <% } %>

                    </div>
                  </td>
                </tr>
              <% } %>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <!-- Search and Grid of Sellers (No Seller Selected yet) -->
    <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 1.5rem; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1.25rem; box-shadow: var(--shadow-sm);">
      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
        <h4 style="margin: 0; font-family: var(--font-display); font-size: 1.1rem; color: var(--text-primary);">
          <i class="fa-solid fa-users-gear" style="color: var(--primary); margin-right: 6px;"></i> Platform Sellers
        </h4>
        <!-- Instant Search Button & Bar -->
        <div style="position: relative; width: 100%; max-width: 320px;">
          <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 14px; top: 12px; color: var(--text-hint); font-size: 0.85rem;"></i>
          <input type="text" id="seller-card-search" class="form-control" placeholder="Search seller name or email..." style="width: 100%; height: 38px; border-radius: 6px; padding-left: 36px; background: #f8fafc; font-size: 0.88rem; border: 1px solid var(--border);">
        </div>
      </div>

      <!-- Sellers Grid -->
      <div id="sellers-cards-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; margin-top: 0.5rem;">
        <% sellers.forEach(s => { %>
          <div class="seller-select-card" data-name="<%= s.name %>" data-email="<%= s.email %>" onclick="window.location.href='/admin/bookings?sellerId=<%= s._id %>'" style="border: 1px solid var(--border); border-radius: var(--radius-md); padding: 1.25rem; text-align: center; cursor: pointer; transition: all 0.2s; background: #ffffff; display: flex; flex-direction: column; align-items: center; gap: 10px; position: relative;">
            <% if (s.avatar && s.avatar.url) { %>
              <img src="<%= s.avatar.url %>" style="width: 70px; height: 70px; border-radius: 50%; object-fit: cover; border: 2.5px solid #cbd5e1; transition: border-color 0.2s;">
            <% } else { %>
              <div style="width: 70px; height: 70px; border-radius: 50%; background-color:#f1f5f9; display:flex; align-items:center; justify-content:center; font-weight:700; font-size: 1.5rem; border: 2.5px solid #cbd5e1; color: var(--text-secondary); transition: border-color 0.2s;"><%= s.name[0] %></div>
            <% } %>
            <div>
              <h5 style="margin: 0 0 2px; font-family: var(--font-display); font-size: 1rem; color: var(--text-primary);"><%= s.name %></h5>
              <p style="margin: 0; font-size: 0.78rem; color: var(--text-hint); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px;"><%= s.email %></p>
            </div>
            <span class="btn btn-outline" style="padding: 5px 12px; font-size: 0.75rem; width: 100%; margin-top: 4px; pointer-events: none; border-radius: 6px; font-weight:600;">View Transaction Log</span>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Style for Hover Effect on Seller Cards -->
    <style>
      .seller-select-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary) !important;
      }
      .seller-select-card:hover img {
        border-color: var(--primary) !important;
      }
      .seller-select-card:hover div {
        border-color: var(--primary) !important;
      }
      .seller-select-card:hover .btn-outline {
        background-color: var(--primary) !important;
        color: #ffffff !important;
        border-color: var(--primary) !important;
      }
    </style>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('seller-card-search');
        const cards = document.querySelectorAll('.seller-select-card');

        searchInput.addEventListener('input', () => {
          const query = searchInput.value.toLowerCase().trim();
          cards.forEach(card => {
            const name = card.getAttribute('data-name').toLowerCase();
            const email = card.getAttribute('data-email').toLowerCase();
            if (name.includes(query) || email.includes(query)) {
              card.style.display = 'flex';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });
    </script>
  <% } %>
</div>

<%- include('../layouts/footer') %>
