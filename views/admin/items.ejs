<%- include('../layouts/main') %>

<div class="container" style="max-width: 1100px;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
    <h2 style="font-family: var(--font-display);"><i class="fa-solid fa-boxes-stacked"></i> Platform Listings Database</h2>
    <a href="/admin/dashboard" class="btn btn-outline">&larr; Back to Dashboard</a>
  </div>

  <!-- Search and Category Filters -->
  <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 1.25rem; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1rem;">
    <!-- Search Bar -->
    <div style="display: flex; gap: 10px; align-items: center;">
      <div style="position: relative; flex: 1;">
        <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 14px; top: 13px; color: var(--text-hint);"></i>
        <input type="text" id="admin-search-input" class="form-control" placeholder="Search listing title, category, seller..." style="width: 100%; height: 42px; border-radius: 6px; padding-left: 40px; background: #ffffff;">
      </div>
      <button id="btn-admin-search" class="btn btn-primary" style="padding: 10px 20px; font-weight: 700; height: 42px; display: flex; align-items: center; gap: 6px; border: none; border-radius: 6px; background-color: var(--primary);">
        <i class="fa-solid fa-magnifying-glass"></i> Search
      </button>
      <button id="btn-admin-reset" class="btn btn-outline" style="padding: 10px 20px; height: 42px; border-radius: 6px; font-weight: 600; cursor: pointer; background: #ffffff;">
        Reset
      </button>
    </div>

    <!-- Category Filter Pills -->
    <div style="display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none;">
      <button class="admin-cat-pill active" data-category="all" style="background: var(--primary); color: #ffffff; border: 1px solid var(--primary); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        All Categories
      </button>
      <button class="admin-cat-pill" data-category="electronics" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Electronics
      </button>
      <button class="admin-cat-pill" data-category="tools" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Tools & Gear
      </button>
      <button class="admin-cat-pill" data-category="vehicles" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Vehicles
      </button>
      <button class="admin-cat-pill" data-category="furniture" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Furniture
      </button>
      <button class="admin-cat-pill" data-category="sports" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Sports
      </button>
      <button class="admin-cat-pill" data-category="clothing" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Clothing
      </button>
      <button class="admin-cat-pill" data-category="other" style="background: #ffffff; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">
        Others
      </button>
    </div>
  </div>

  <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
      <thead>
        <tr style="border-bottom: 2px solid var(--border); color: var(--text-secondary); font-weight: 600;">
          <th style="padding: 10px 8px;">Listing Title</th>
          <th style="padding: 10px 8px;">Category</th>
          <th style="padding: 10px 8px;">Seller</th>
          <th style="padding: 10px 8px;">Price / Day</th>
          <th style="padding: 10px 8px;">Safety Status</th>
          <th style="padding: 10px 8px; text-align: center;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length === 0) { %>
          <tr>
            <td colspan="6" style="padding: 20px; text-align: center; color: var(--text-hint);">No items found on the marketplace.</td>
          </tr>
        <% } else { %>
          <% items.forEach(item => { %>
            <tr class="admin-item-row" data-category="<%= item.category %>" style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px 8px; font-weight: 600;">
                <a href="/items/<%= item._id %>" target="_blank" class="item-title-link"><%= item.title %></a>
              </td>
              <td style="padding: 12px 8px; text-transform: capitalize;" class="item-category-cell"><%= item.category %></td>
              <td style="padding: 12px 8px;" class="item-owner-cell"><%= item.owner ? item.owner.name : 'Unknown Owner' %></td>
              <td style="padding: 12px 8px; font-weight: 700;">₹<%= item.pricePerDay %></td>
              <td style="padding: 12px 8px;">
                <span style="font-size:0.75rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;
                  <%= item.status === 'active' ? 'background-color:#dcfce7; color:#15803d;' : '' %>
                  <%= item.status === 'pending_review' ? 'background-color:#fef3c7; color:#d97706;' : '' %>
                  <%= item.status === 'rejected' ? 'background-color:#fee2e2; color:#dc2626;' : '' %>
                ">
                  <%= item.status %>
                </span>
              </td>
              <td style="padding: 12px 8px; text-align: center; display:flex; gap:6px; justify-content:center; align-items:center;">
                <% if (item.status === 'pending_review' || item.status === 'rejected') { %>
                  <form action="/admin/items/<%= item._id %>/status?_method=PUT" method="POST" style="display: inline;">
                    <input type="hidden" name="status" value="active">
                    <button type="submit" class="btn btn-primary" style="padding: 4px 8px; font-size: 0.75rem;"><i class="fa-solid fa-check"></i> Approve</button>
                  </form>
                <% } else { %>
                  <form action="/admin/items/<%= item._id %>/status?_method=PUT" method="POST" style="display: inline;">
                    <input type="hidden" name="status" value="rejected">
                    <button type="submit" class="btn btn-danger" style="padding: 4px 8px; font-size: 0.75rem;"><i class="fa-solid fa-ban"></i> Block</button>
                  </form>
                <% } %>
                <form action="/admin/items/<%= item._id %>?_method=DELETE" method="POST" style="display: inline;" onsubmit="return confirm('Delete this listing permanently?')">
                  <button type="submit" class="btn btn-danger" style="padding: 4px 8px; font-size: 0.75rem;"><i class="fa-solid fa-trash"></i> Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('admin-search-input');
    const searchBtn = document.getElementById('btn-admin-search');
    const resetBtn = document.getElementById('btn-admin-reset');
    const pills = document.querySelectorAll('.admin-cat-pill');
    const rows = document.querySelectorAll('.admin-item-row');

    let currentCategory = 'all';

    function filterAdminListings() {
      const query = searchInput.value.toLowerCase().trim();
      
      rows.forEach(row => {
        const title = row.querySelector('.item-title-link').textContent.toLowerCase();
        const category = row.getAttribute('data-category').toLowerCase();
        const owner = row.querySelector('.item-owner-cell').textContent.toLowerCase();
        
        const matchesCategory = (currentCategory === 'all' || category === currentCategory);
        const matchesQuery = (!query || title.includes(query) || category.includes(query) || owner.includes(query));

        if (matchesCategory && matchesQuery) {
          row.style.display = 'table-row';
        } else {
          row.style.display = 'none';
        }
      });
    }

    // Pill click handler
    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => {
          p.classList.remove('active');
          p.style.background = '#ffffff';
          p.style.color = 'var(--text-secondary)';
          p.style.borderColor = 'var(--border)';
        });
        
        pill.classList.add('active');
        pill.style.background = 'var(--primary)';
        pill.style.color = '#ffffff';
        pill.style.borderColor = 'var(--primary)';

        currentCategory = pill.getAttribute('data-category');
        filterAdminListings();
      });
    });

    searchBtn.addEventListener('click', filterAdminListings);
    searchInput.addEventListener('keyup', (e) => {
      if (e.key === 'Enter') {
        filterAdminListings();
      }
    });

    resetBtn.addEventListener('click', () => {
      searchInput.value = '';
      currentCategory = 'all';
      
      pills.forEach(p => {
        p.classList.remove('active');
        p.style.background = '#ffffff';
        p.style.color = 'var(--text-secondary)';
        p.style.borderColor = 'var(--border)';
      });
      const firstPill = pills[0];
      firstPill.classList.add('active');
      firstPill.style.background = 'var(--primary)';
      firstPill.style.color = '#ffffff';
      firstPill.style.borderColor = 'var(--primary)';

      rows.forEach(row => row.style.display = 'table-row');
    });
  });
</script>

<%- include('../layouts/footer') %>
