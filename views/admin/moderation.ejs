<%- include('../layouts/main') %>

<div class="container" style="max-width: 1100px;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
    <h2 style="font-family: var(--font-display);"><i class="fa-solid fa-triangle-exclamation"></i> Content Moderation Queue</h2>
    <a href="/admin/dashboard" class="btn btn-outline">&larr; Back to Dashboard</a>
  </div>

  <% if (items.length === 0) { %>
    <div style="text-align: center; padding: 4rem 2rem; background-color: var(--surface); border: 1px dashed var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);">
      <div style="font-size: 3rem; color: var(--success); margin-bottom: 1.25rem;"><i class="fa-solid fa-circle-check"></i></div>
      <h3 style="margin-bottom: 0.5rem; font-family: var(--font-display);">Queue is Empty</h3>
      <p style="color: var(--text-secondary);">No flagged listings are currently awaiting moderation review.</p>
    </div>
  <% } else { %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      <% items.forEach(item => { %>
        <div class="item-card" style="border-color: var(--warning); border-width: 2px;">
          
          <div class="item-card-img-wrapper">
            <% if (item.images && item.images.length > 0) { %>
              <img src="<%= item.images[0].url %>" class="item-card-img" alt="<%= item.title %>">
            <% } else { %>
              <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--text-hint); font-size: 2rem; background: #e2e8f0;"><i class="fa-solid fa-camera"></i></div>
            <% } %>
            <div class="item-card-badge" style="background-color: var(--warning);"><%= item.category %></div>
          </div>

          <div class="item-card-content">
            <h3 class="item-card-title"><%= item.title %></h3>
            <span style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 8px;">Seller: <strong><%= item.owner ? item.owner.name : 'Unknown' %></strong></span>
            
            <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1rem; flex: 1; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
              <%= item.description %>
            </p>

            <div style="background-color: #fffbeb; border: 1px solid #fde68a; border-radius: var(--radius-sm); padding: 8px 12px; margin-bottom: 1rem; font-size: 0.8rem; color: #b45309;">
              <i class="fa-solid fa-flag"></i> Flagged: Medium severity text detected.
            </div>

            <div style="display: flex; gap: 8px; border-top: 1px solid var(--border); padding-top: 0.75rem;">
              <form action="/admin/moderation/<%= item._id %>?_method=PUT" method="POST" style="flex: 1;">
                <input type="hidden" name="action" value="approve">
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 6px; font-size: 0.8rem;"><i class="fa-solid fa-circle-check"></i> Keep</button>
              </form>
              <form action="/admin/moderation/<%= item._id %>?_method=PUT" method="POST" style="flex: 1;">
                <input type="hidden" name="action" value="reject">
                <button type="submit" class="btn btn-danger" style="width: 100%; padding: 6px; font-size: 0.8rem;"><i class="fa-solid fa-trash"></i> Remove</button>
              </form>
            </div>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
