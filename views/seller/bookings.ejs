<%- include('../layouts/main') %>

<div class="container">
  <h2 style="font-family: var(--font-display); margin-bottom: 2rem;">Rental Operations Calendar</h2>

    <!-- Monthly Calendar -->
    <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); margin-bottom: 2.5rem;">
      <h3 style="font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
        <span id="calendar-month-year">June 2026</span>
      </h3>
      
      <div class="calendar-grid">
        <!-- Sun to Sat -->
        <div class="calendar-day-header">Sun</div>
        <div class="calendar-day-header">Mon</div>
        <div class="calendar-day-header">Tue</div>
        <div class="calendar-day-header">Wed</div>
        <div class="calendar-day-header">Thu</div>
        <div class="calendar-day-header">Fri</div>
        <div class="calendar-day-header">Sat</div>
        
        <!-- Cells generated by client script -->
        <% for(let i=1; i<=35; i++) { %>
          <div class="calendar-cell">
            <span class="calendar-date-number" id="cal-date-<%= i %>"></span>
            <div id="cal-events-<%= i %>" style="display:flex; flex-direction:column; gap:2px;"></div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Booking Lists Categorized -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
      
      <!-- 1. PENDING REQUESTS -->
      <% const pendingBookings = bookings.filter(b => b.status === 'pending'); %>
      <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 1rem; color: #d97706; display: flex; align-items: center; gap: 8px; margin-top: 0;">
          <i class="fa-solid fa-clock-rotate-left"></i> Pending Reservation Requests (<%= pendingBookings.length %>)
        </h3>
        <% if (pendingBookings.length === 0) { %>
          <p style="color: var(--text-hint); text-align: center; padding: 1.5rem; margin: 0; font-size: 0.9rem;">No pending requests awaiting approval.</p>
        <% } else { %>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <% pendingBookings.forEach(booking => { %>
              <%- include('../partials/sellerBookingCard', { booking: booking }) %>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- 2. CONFIRMED & ACTIVE BOOKINGS -->
      <% const activeBookings = bookings.filter(b => b.status === 'confirmed' || b.status === 'active'); %>
      <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 1rem; color: var(--primary); display: flex; align-items: center; gap: 8px; margin-top: 0;">
          <i class="fa-solid fa-circle-check"></i> Confirmed Bookings (Items Rented Out) (<%= activeBookings.length %>)
        </h3>
        <% if (activeBookings.length === 0) { %>
          <p style="color: var(--text-hint); text-align: center; padding: 1.5rem; margin: 0; font-size: 0.9rem;">No items currently rented or confirmed.</p>
        <% } else { %>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <% activeBookings.forEach(booking => { %>
              <%- include('../partials/sellerBookingCard', { booking: booking }) %>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- 3. COMPLETED / RETURNED BOOKINGS -->
      <% const completedBookings = bookings.filter(b => b.status === 'completed'); %>
      <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 1rem; color: var(--success); display: flex; align-items: center; gap: 8px; margin-top: 0;">
          <i class="fa-solid fa-circle-arrow-down"></i> Items Taken Back (Completed Rentals) (<%= completedBookings.length %>)
        </h3>
        <% if (completedBookings.length === 0) { %>
          <p style="color: var(--text-hint); text-align: center; padding: 1.5rem; margin: 0; font-size: 0.9rem;">No completed or returned rentals yet.</p>
        <% } else { %>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <% completedBookings.forEach(booking => { %>
              <%- include('../partials/sellerBookingCard', { booking: booking }) %>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>

</div>

<script>
  function toggleActionForm(bookingId, actionType) {
    const formDiv = document.getElementById(actionType + '-form-' + bookingId);
    if (formDiv) {
      if (formDiv.style.display === 'none') {
        formDiv.style.display = 'block';
      } else {
        formDiv.style.display = 'none';
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Populate simple calendar cells for current month (June 2026)
    // June 1 2026 starts on Monday (Monday = cell index 2)
    const startDayOffset = 1; 
    const totalDaysInMonth = 30;

    for (let i = 1; i <= totalDaysInMonth; i++) {
      const cellIndex = i + startDayOffset;
      const dateNumSpan = document.getElementById('cal-date-' + cellIndex);
      if (dateNumSpan) {
        dateNumSpan.textContent = i;
      }
    }

    // Populate events from database
    const bookingsData = <%- JSON.stringify(bookings) %>;
    bookingsData.forEach(booking => {
      if (booking.status === 'confirmed' || booking.status === 'active') {
        const start = new Date(booking.startDate);
        const end = new Date(booking.endDate);
        
        // Loop over days
        for(let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
          if (d.getMonth() === 5 && d.getFullYear() === 2026) { // June 2026
            const dayNum = d.getDate();
            const cellIndex = dayNum + startDayOffset;
            const eventDiv = document.getElementById('cal-events-' + cellIndex);
            
            if (eventDiv) {
              const eventEl = document.createElement('div');
              eventEl.classList.add('calendar-event');
              eventEl.textContent = booking.item ? booking.item.title : 'Rented';
              eventEl.title = `Rented by ${booking.renter.name}`;
              eventDiv.appendChild(eventEl);
            }
          }
        }
      }
    });
  });
</script>

<%- include('../layouts/footer') %>
