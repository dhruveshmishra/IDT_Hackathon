<%- include('../layouts/main') %>

<div class="container" style="max-width: 760px;">
  <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-sm);">
      <h3 style="font-family: var(--font-display); font-size: 1.4rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 8px;">
        <i class="fa-solid fa-shield-halved" style="color: var(--primary);"></i> Seller Verification Flow
      </h3>
      <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem;">Upload business registrations (GSTIN/MSME) or local verification credentials to mark your listings as verified.</p>

      <% if (currentUser.isVerified) { %>
        <div style="background-color: #dcfce7; border-left: 4px solid var(--success); padding: 12px; border-radius: var(--radius-sm); color: #15803d; font-size: 0.95rem; font-weight: 600; margin-bottom: 1.5rem;">
          <i class="fa-solid fa-circle-check"></i> Congratulations! Your Seller Profile is verified.
        </div>
      <% } else if (currentUser.sellerProfile && currentUser.sellerProfile.verificationDoc && currentUser.sellerProfile.verificationDoc.url) { %>
        <div style="background-color: #fef3c7; border-left: 4px solid var(--warning); padding: 12px; border-radius: var(--radius-sm); color: #b45309; font-size: 0.95rem; font-weight: 600; margin-bottom: 1.5rem;">
          <i class="fa-solid fa-clock"></i> Verification doc submitted. Admin is currently reviewing.
        </div>
      <% } %>

      <form action="/seller/verify" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label for="businessName">Registered Business / Shop Name</label>
          <input type="text" name="businessName" id="businessName" class="form-control" value="<%= currentUser.sellerProfile.businessName || '' %>" placeholder="e.g. Sharma Camera Rentals" required>
        </div>

        <div class="form-group">
          <label for="description">Short Business Description</label>
          <textarea name="description" id="description" rows="3" class="form-control" placeholder="Provide a brief description of the products you plan to list..." required><%= currentUser.sellerProfile.description || '' %></textarea>
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
          <label for="verificationDoc">Business Document Photo (GSTIN / Trade License / shop photos)</label>
          <input type="file" name="verificationDoc" id="verificationDoc" class="form-control" accept="image/*" required>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;"><i class="fa-solid fa-upload"></i> Submit Documents for Review</button>
      </form>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
