<%- include('../layouts/main') %>

<div class="container" style="max-width: 900px;">
  <div style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-md);">
    
    <!-- Header -->
    <div style="border-bottom: 1px solid var(--border); padding-bottom: 1.25rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
      <div>
        <h2 style="font-family: var(--font-display); margin: 0; display: flex; align-items: center; gap: 10px;">
          <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--primary);"></i> Seller AI Damage Inspector
        </h2>
        <p style="color: var(--text-secondary); font-size: 0.88rem; margin: 6px 0 0 0;">
          Compare before and after return photos of rental items using Gemini AI to detect damages and locate them.
        </p>
      </div>
      <i class="fa-solid fa-microscope" style="font-size: 2.5rem; color: var(--primary-light);"></i>
    </div>

    <!-- Alert / Banner info -->
    <div style="background: #eff6ff; border: 1px solid #bfdbfe; border-radius: var(--radius-md); padding: 1rem 1.25rem; margin-bottom: 2rem; display: flex; gap: 12px; align-items: flex-start;">
      <i class="fa-solid fa-circle-info" style="color: var(--primary); font-size: 1.1rem; margin-top: 2px;"></i>
      <span style="font-size: 0.85rem; color: #1e3a8a; line-height: 1.45;">
        You can test this sandbox tool by uploading two photos below. Optionally link the assessment to an active booking from your seller history to save the analysis as a formal dispute.
      </span>
    </div>

    <!-- Main Inspection Form -->
    <form id="ai-inspection-form" style="display: flex; flex-direction: column; gap: 1.5rem;">
      
      <!-- Selection of Booking / Custom Item -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        
        <div class="form-group">
          <label for="booking-select" style="font-weight: 700; font-size: 0.85rem; display: block; margin-bottom: 6px;">Link to Booking (Optional)</label>
          <select id="booking-select" class="form-control" style="background:#ffffff; height: 42px; border-radius: 6px;">
            <option value="custom">-- Run Standalone Sandbox --</option>
            <% bookings.forEach(b => { %>
              <option value="<%= b._id %>" data-title="<%= b.item ? b.item.title : 'Rented Item' %>">
                <%= b.item ? b.item.title : 'Rented Item' %> (Ref: <%= b._id.toString().substring(0,8) %>...)
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="item-title-input" style="font-weight: 700; font-size: 0.85rem; display: block; margin-bottom: 6px;">Item Description / Name</label>
          <input type="text" id="item-title-input" class="form-control" placeholder="E.g., Sony Alpha 7 camera, Mountain Cycle..." required style="height: 42px; border-radius: 6px;">
        </div>

      </div>

      <!-- Upload Slots Row -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        
        <!-- Before Upload Slot -->
        <div>
          <label style="font-size: 0.82rem; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 8px;">
            Photo BEFORE renting <span style="color:var(--danger)">*</span>
          </label>
          <div id="before-dropzone" style="
            border: 2px dashed #cbd5e1; border-radius: var(--radius-md); padding: 2rem 1.5rem;
            text-align: center; cursor: pointer; transition: all 0.2s ease; background: #f8fafc;
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; min-height: 160px;
          " onclick="document.getElementById('beforeImage').click();">
            <i class="fa-solid fa-image" id="before-icon" style="font-size: 2rem; color: var(--text-hint); transition: color 0.2s;"></i>
            <span id="before-text" style="font-size: 0.825rem; color: var(--text-secondary); font-weight: 600;">Click to upload BEFORE photo</span>
            <span id="before-subtext" style="font-size: 0.7rem; color: var(--text-hint);">Supports JPG, PNG</span>
            <img id="before-preview" src="" style="display: none; max-width: 100%; max-height: 120px; object-fit: contain; border-radius: var(--radius-sm); border: 1px solid var(--border);">
          </div>
          <input type="file" id="beforeImage" name="beforeImage" accept="image/*" required style="display: none;">
        </div>

        <!-- After Upload Slot -->
        <div>
          <label style="font-size: 0.82rem; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 8px;">
            Photo AFTER renting / return <span style="color:var(--danger)">*</span>
          </label>
          <div id="after-dropzone" style="
            border: 2px dashed #cbd5e1; border-radius: var(--radius-md); padding: 2rem 1.5rem;
            text-align: center; cursor: pointer; transition: all 0.2s ease; background: #f8fafc;
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; min-height: 160px;
          " onclick="document.getElementById('afterImage').click();">
            <i class="fa-solid fa-image-portrait" id="after-icon" style="font-size: 2rem; color: var(--text-hint); transition: color 0.2s;"></i>
            <span id="after-text" style="font-size: 0.825rem; color: var(--text-secondary); font-weight: 600;">Click to upload AFTER photo</span>
            <span id="after-subtext" style="font-size: 0.7rem; color: var(--text-hint);">Supports JPG, PNG</span>
            <img id="after-preview" src="" style="display: none; max-width: 100%; max-height: 120px; object-fit: contain; border-radius: var(--radius-sm); border: 1px solid var(--border);">
          </div>
          <input type="file" id="afterImage" name="afterImage" accept="image/*" required style="display: none;">
        </div>

      </div>

      <button type="submit" id="btn-submit-inspection" class="btn btn-primary" style="width: 100%; padding: 12px 20px; font-size: 0.95rem; font-weight: 700; margin-top: 0.5rem; background-color: var(--primary); border: none; border-radius: 6px;">
        <i class="fa-solid fa-microscope"></i> Start AI Verification
      </button>

    </form>

    <!-- Inspection Output Results -->
    <div id="inspection-results-card" style="display: none; margin-top: 2.5rem; border-top: 1px dashed var(--border); padding-top: 2rem; flex-direction: column; gap: 1.5rem;">
      <h3 style="font-family: var(--font-display); color: var(--primary); display: flex; align-items: center; gap: 8px; font-size: 1.2rem; margin: 0;">
        <i class="fa-solid fa-square-poll-vertical"></i> Gemini Analysis Results
      </h3>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
        <div>
          <span style="font-size: 0.72rem; color: var(--text-hint); text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 4px;">Uploaded Before</span>
          <img id="result-before-img" src="" style="width:100%; max-height: 180px; object-fit: contain; border: 1px solid var(--border); border-radius: 6px; background:#f8fafc;">
        </div>
        <div>
          <span style="font-size: 0.72rem; color: var(--text-hint); text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 4px;">Uploaded After</span>
          <img id="result-after-img" src="" style="width:100%; max-height: 180px; object-fit: contain; border: 1px solid var(--border); border-radius: 6px; background:#f8fafc;">
        </div>
      </div>

      <div style="background-color: #f8fafc; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
          <div>
            <span style="font-size: 0.68rem; color: var(--text-hint); text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 4px;">Damage Severity</span>
            <span id="result-severity-badge" class="badge" style="font-size: 0.8rem; padding: 4px 12px; border-radius: 99px;">N/A</span>
          </div>
          <div>
            <span style="font-size: 0.68rem; color: var(--text-hint); text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 4px;">Detected Location</span>
            <span id="result-location-badge" style="background-color: #eff6ff; border:1px solid #bfdbfe; color: #1e40af; font-size: 0.8rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; display: inline-flex; align-items: center; gap: 6px; text-transform: uppercase;">
              <i class="fa-solid fa-crosshairs"></i> <span id="result-location-text">N/A</span>
            </span>
          </div>
        </div>

        <div style="border-top: 1px solid var(--border); padding-top: 1rem;">
          <span style="font-size: 0.68rem; color: var(--text-hint); text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 4px;">Damage Description</span>
          <p id="result-description" style="color: var(--text-primary); font-size: 0.9rem; margin: 0; line-height: 1.5; font-style: italic;"></p>
        </div>

        <div style="border-top: 1px solid var(--border); padding-top: 1rem;">
          <span style="font-size: 0.68rem; color: var(--text-hint); text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 4px;">AI Reasoning / Logic</span>
          <p id="result-reasoning" style="color: var(--text-secondary); font-size: 0.88rem; margin: 0; line-height: 1.5;"></p>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bookingSelect = document.getElementById('booking-select');
    const itemTitleInput = document.getElementById('item-title-input');
    
    const beforeInput = document.getElementById('beforeImage');
    const beforeDropzone = document.getElementById('before-dropzone');
    const beforeIcon = document.getElementById('before-icon');
    const beforeText = document.getElementById('before-text');
    const beforeSubtext = document.getElementById('before-subtext');
    const beforePreview = document.getElementById('before-preview');

    const afterInput = document.getElementById('afterImage');
    const afterDropzone = document.getElementById('after-dropzone');
    const afterIcon = document.getElementById('after-icon');
    const afterText = document.getElementById('after-text');
    const afterSubtext = document.getElementById('after-subtext');
    const afterPreview = document.getElementById('after-preview');

    const form = document.getElementById('ai-inspection-form');
    const resultsCard = document.getElementById('inspection-results-card');

    // Sync Item Title input dynamically when selecting booking
    bookingSelect.addEventListener('change', () => {
      const selectedOpt = bookingSelect.options[bookingSelect.selectedIndex];
      if (selectedOpt.value === 'custom') {
        itemTitleInput.value = '';
        itemTitleInput.disabled = false;
        itemTitleInput.focus();
      } else {
        itemTitleInput.value = selectedOpt.getAttribute('data-title') || '';
        itemTitleInput.disabled = true;
      }
    });

    // Before Preview Handler
    beforeInput.onchange = () => {
      if (beforeInput.files && beforeInput.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          beforePreview.src = e.target.result;
          beforePreview.style.display = 'block';
          beforeIcon.style.display = 'none';
          beforeText.style.display = 'none';
          beforeSubtext.style.display = 'none';
          beforeDropzone.style.borderColor = '#16a34a';
          beforeDropzone.style.background = '#f0fdf4';
        };
        reader.readAsDataURL(beforeInput.files[0]);
      }
    };

    // After Preview Handler
    afterInput.onchange = () => {
      if (afterInput.files && afterInput.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          afterPreview.src = e.target.result;
          afterPreview.style.display = 'block';
          afterIcon.style.display = 'none';
          afterText.style.display = 'none';
          afterSubtext.style.display = 'none';
          afterDropzone.style.borderColor = '#16a34a';
          afterDropzone.style.background = '#f0fdf4';
        };
        reader.readAsDataURL(afterInput.files[0]);
      }
    };

    // AJAX submit handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      window.showAILoader('Gemini AI is analyzing before & after photos for damage details...');
      resultsCard.style.display = 'none';

      try {
        const formData = new FormData();
        formData.append('bookingId', bookingSelect.value);
        formData.append('itemTitle', itemTitleInput.value);
        formData.append('beforeImage', beforeInput.files[0]);
        formData.append('afterImage', afterInput.files[0]);

        const res = await fetch('/seller/inspection', {
          method: 'POST',
          body: formData
        });

        const data = await res.json();
        window.hideAILoader();

        if (data.success) {
          // Populate results
          document.getElementById('result-before-img').src = data.beforeImage;
          document.getElementById('result-after-img').src = data.afterImage;
          
          const badge = document.getElementById('result-severity-badge');
          badge.textContent = data.severity.toUpperCase();
          badge.className = 'badge';
          if (data.severity.toLowerCase() === 'high' || data.severity.toLowerCase() === 'severe') {
            badge.classList.add('badge-danger');
          } else if (data.severity.toLowerCase() === 'medium' || data.severity.toLowerCase() === 'moderate') {
            badge.classList.add('badge-warning');
          } else {
            badge.classList.add('badge-success');
          }

          document.getElementById('result-location-text').textContent = (data.damageLocation || 'none').toUpperCase();
          document.getElementById('result-description').textContent = `"${data.description}"`;
          document.getElementById('result-reasoning').textContent = data.reasoning;

          resultsCard.style.display = 'flex';
          
          // Scroll to results smoothly
          resultsCard.scrollIntoView({ behavior: 'smooth' });
        } else {
          alert('AI Inspection failed: ' + data.error);
        }
      } catch (err) {
        window.hideAILoader();
        alert('Inspection request error: ' + err.message);
      }
    });

  });
</script>

<%- include('../layouts/footer') %>
