<%- include('../layouts/main') %>
<% locals.activePage = 'profile'; %>

<div class="container">
  <div style="margin-bottom: 2rem;">
    <h1 style="font-size: 1.8rem; margin-bottom: 0.25rem;">Seller Profile</h1>
    <p style="color: var(--text-secondary);">Manage your business info, Aadhaar verification, and payout details.</p>
  </div>

  <!-- Approval Status Banner -->
  <% if (currentUser && !currentUser.sellerApproved) { %>
  <div class="approval-banner pending" style="margin-bottom: 1.5rem;">
    <span class="approval-banner-icon"><i class="fa-solid fa-hourglass-half"></i></span>
    <div>
      <strong>Account Pending Admin Approval</strong><br>
      <span style="font-size: 0.88rem;">Your seller account is being reviewed. You'll receive an email once approved.</span>
    </div>
  </div>
  <% } else if (currentUser && currentUser.sellerApproved) { %>
  <div class="approval-banner approved" style="margin-bottom: 1.5rem;">
    <span class="approval-banner-icon"><i class="fa-solid fa-circle-check"></i></span>
    <div>
      <strong>Seller Account Approved</strong><br>
      <% if (currentUser.isVerified) { %>
        <span style="font-size: 0.88rem;">Your documents are verified. You can publish listings.</span>
      <% } else { %>
        <span style="font-size: 0.88rem;">Please upload verification documents to publish listings.</span>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="profile-layout">
    <!-- Left: Avatar + Summary -->
    <div>
      <div class="profile-sidebar-card">
        <div class="profile-avatar-wrapper">
          <div class="profile-avatar">
            <% if (currentUser.avatar && currentUser.avatar.url) { %>
              <img src="<%= currentUser.avatar.url %>" alt="Profile avatar">
            <% } else { %>
              <i class="fa-solid fa-user-tie"></i>
            <% } %>
          </div>
          <label for="avatarQuickUpload" class="profile-avatar-edit" title="Change photo">
            <i class="fa-solid fa-pen"></i>
          </label>
        </div>

        <div class="profile-name">
          <%= currentUser.sellerProfile && currentUser.sellerProfile.businessName ? currentUser.sellerProfile.businessName : currentUser.name %>
        </div>
        <div style="margin: 0.4rem 0 0.75rem;">
          <span class="profile-role-badge"><i class="fa-solid fa-store"></i> Seller</span>
          <% if (currentUser.isVerified) { %>
            <span class="badge badge-success" style="margin-left:4px;"><i class="fa-solid fa-check"></i> Verified</span>
          <% } else { %>
            <span class="badge badge-warning" style="margin-left:4px;"><i class="fa-solid fa-clock"></i> Pending</span>
          <% } %>
        </div>
        <p style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.5rem;">
          <i class="fa-solid fa-envelope"></i> <%= currentUser.email %>
        </p>
        <% if (currentUser.phone) { %>
        <p style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.5rem;">
          <i class="fa-solid fa-phone"></i> <%= currentUser.phone %>
        </p>
        <% } %>
        <% if (currentUser.sellerProfile && currentUser.sellerProfile.address) { %>
        <p style="font-size:0.85rem; color:var(--text-secondary);">
          <i class="fa-solid fa-location-dot"></i> <%= currentUser.sellerProfile.address %>
        </p>
        <% } %>

        <div class="profile-stat-row">
          <div class="profile-stat">
            <div class="profile-stat-value">₹<%= (currentUser.sellerProfile && currentUser.sellerProfile.earnings) ? currentUser.sellerProfile.earnings.toFixed(0) : '0' %></div>
            <div class="profile-stat-label">Earnings</div>
          </div>
          <div class="profile-stat">
            <div class="profile-stat-value">
              <% if (currentUser.aadhaarVerified) { %>
                <i class="fa-solid fa-circle-check" style="color: var(--success); font-size: 1.5rem;"></i>
              <% } else { %>
                <i class="fa-solid fa-circle-xmark" style="color: var(--danger); font-size: 1.5rem;"></i>
              <% } %>
            </div>
            <div class="profile-stat-label">KYC</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Edit Forms -->
    <div>

      <!-- Profile Info Form -->
      <div class="profile-form-card">
        <div class="profile-section-title">
          <i class="fa-solid fa-pen-to-square" style="color: var(--primary);"></i> Profile & Business Info
        </div>

        <form action="/seller/profile" method="POST" enctype="multipart/form-data">
          <input type="file" name="avatar" id="avatarQuickUpload" style="display:none;" accept="image/*"
            onchange="this.form.submit()">

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" name="name" id="name" class="form-control" value="<%= currentUser.name %>" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" name="phone" id="phone" class="form-control" value="<%= currentUser.phone || '' %>">
            </div>
            <div class="form-group">
              <label for="businessName">Business / Shop Name</label>
              <input type="text" name="businessName" id="businessName" class="form-control"
                value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.businessName) ? currentUser.sellerProfile.businessName : '' %>"
                placeholder="My Rental Store">
            </div>
            <div class="form-group">
              <label for="aadhaarNumber">Aadhaar Number</label>
              <input type="text" name="aadhaarNumber" id="aadhaarNumber" class="form-control"
                value="<%= currentUser.aadhaarNumber ? currentUser.aadhaarNumber.replace(/(\d{4})(\d{4})(\d{4})/, '$1 $2 $3') : '' %>"
                placeholder="XXXX XXXX XXXX" maxlength="14"
                oninput="formatAadhaar(this)">
            </div>
          </div>

          <div class="form-group">
            <label for="description">Business Description</label>
            <textarea name="description" id="description" class="form-control" rows="3"
              placeholder="Describe your rental business..."><%= (currentUser.sellerProfile && currentUser.sellerProfile.description) ? currentUser.sellerProfile.description : '' %></textarea>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <!-- Personal Address with autocomplete -->
            <div class="form-group" style="grid-column: 1/-1; position: relative;">
              <label for="address">
                Personal Address
                <span style="font-size:0.78rem; font-weight:400; color: var(--text-hint);">(visible to renters)</span>
              </label>
              <div style="position: relative;">
                <input type="text" name="address" id="address" class="form-control"
                  value="<%= currentUser.address || '' %>"
                  placeholder="Your personal address" autocomplete="off" style="padding-right: 30px;">
                <i class="fa-solid fa-magnifying-glass" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); color:var(--text-hint); pointer-events:none;"></i>
                <div id="personal-address-suggestions" style="
                  display:none; position:absolute; top:100%; left:0; right:0;
                  background:#fff; border:1px solid var(--border); border-top:none;
                  border-radius:0 0 var(--radius-md) var(--radius-md);
                  box-shadow:var(--shadow-md); z-index:9999; max-height:180px; overflow-y:auto;">
                </div>
              </div>
            </div>

            <!-- Business Address with autocomplete -->
            <div class="form-group" style="grid-column: 1/-1; position: relative;">
              <label for="businessAddress">Business Address</label>
              <div style="position: relative;">
                <input type="text" name="businessAddress" id="businessAddress" class="form-control"
                  value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.address) ? currentUser.sellerProfile.address : '' %>"
                  placeholder="Shop / warehouse address" autocomplete="off" style="padding-right: 30px;">
                <i class="fa-solid fa-magnifying-glass" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); color:var(--text-hint); pointer-events:none;"></i>
                <div id="business-address-suggestions" style="
                  display:none; position:absolute; top:100%; left:0; right:0;
                  background:#fff; border:1px solid var(--border); border-top:none;
                  border-radius:0 0 var(--radius-md) var(--radius-md);
                  box-shadow:var(--shadow-md); z-index:9999; max-height:180px; overflow-y:auto;">
                </div>
              </div>
            </div>
          </div>

          <div class="profile-section-title" style="margin-top: 1.5rem;">
            <i class="fa-solid fa-wallet" style="color: var(--success);"></i> Payout Details
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
            <div class="form-group" style="grid-column: 1 / -1;">
              <label for="upi">UPI ID</label>
              <input type="text" name="upi" id="upi" class="form-control"
                value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.payoutDetails && currentUser.sellerProfile.payoutDetails.upi) ? currentUser.sellerProfile.payoutDetails.upi : '' %>"
                placeholder="yourname@upi">
            </div>
            <div class="form-group">
              <label for="bankName">Bank Name</label>
              <input type="text" name="bankName" id="bankName" class="form-control"
                value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.payoutDetails && currentUser.sellerProfile.payoutDetails.bankName) ? currentUser.sellerProfile.payoutDetails.bankName : '' %>"
                placeholder="e.g. State Bank of India">
            </div>
            <div class="form-group">
              <label for="bankHolderName">Account Holder Name</label>
              <input type="text" name="bankHolderName" id="bankHolderName" class="form-control"
                value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.payoutDetails && currentUser.sellerProfile.payoutDetails.bankHolderName) ? currentUser.sellerProfile.payoutDetails.bankHolderName : '' %>"
                placeholder="Name as in bank records">
            </div>
            <div class="form-group">
              <label for="bankAccount">Bank Account Number</label>
              <input type="text" name="bankAccount" id="bankAccount" class="form-control"
                value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.payoutDetails && currentUser.sellerProfile.payoutDetails.bankAccount) ? currentUser.sellerProfile.payoutDetails.bankAccount : '' %>"
                placeholder="XXXXXXXX1234">
            </div>
            <div class="form-group">
              <label for="bankIfsc">IFSC Code</label>
              <input type="text" name="bankIfsc" id="bankIfsc" class="form-control"
                value="<%= (currentUser.sellerProfile && currentUser.sellerProfile.payoutDetails && currentUser.sellerProfile.payoutDetails.bankIfsc) ? currentUser.sellerProfile.payoutDetails.bankIfsc : '' %>"
                placeholder="e.g. SBIN0001234">
            </div>
          </div>

          <!-- GPS Location with Map -->
          <div style="background: #f8fafc; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 1.25rem; margin-bottom: 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
              <label style="margin: 0; font-size: 0.9rem; font-weight: 600;">
                <i class="fa-solid fa-location-crosshairs" style="color: var(--primary);"></i>
                Your Store GPS Location
                <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-hint);">(used to locate your listings)</span>
              </label>
              <button type="button" class="btn btn-outline btn-sm" id="detectLocBtn" style="padding: 4px 10px; font-size: 0.8rem;">
                <i class="fa-solid fa-crosshairs"></i> Detect
              </button>
            </div>

            <!-- Leaflet Map Picker -->
            <div style="height:200px; margin-bottom:0.75rem; border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden; position:relative;">
              <div id="location-picker-map" style="width:100%; height:100%;"></div>
              <div style="position:absolute; bottom:8px; right:8px; background:rgba(255,255,255,0.9); border-radius:6px; padding:4px 8px; font-size:0.7rem; color:var(--text-secondary); pointer-events:none; box-shadow:var(--shadow-sm); z-index: 1000;">
                <i class="fa-solid fa-hand-pointer"></i> Drag pin to adjust GPS location
              </div>
            </div>

            <input type="hidden" name="lat" id="latInput" value="<%= currentUser.location && currentUser.location.coordinates ? currentUser.location.coordinates[1] : '' %>">
            <input type="hidden" name="lng" id="lngInput" value="<%= currentUser.location && currentUser.location.coordinates ? currentUser.location.coordinates[0] : '' %>">
            <p id="gpsStatus" style="font-size: 0.82rem; color: var(--text-secondary); margin: 0;">
              <% if (currentUser.location && currentUser.location.coordinates && currentUser.location.coordinates[0]) { %>
                <i class="fa-solid fa-check-circle" style="color:var(--success);"></i>
                Saved: (<span id="savedLatVal"><%= currentUser.location.coordinates[1].toFixed(5) %></span>, <span id="savedLngVal"><%= currentUser.location.coordinates[0].toFixed(5) %></span>)
              <% } else { %>
                <i class="fa-solid fa-circle-info"></i> No location saved yet — click Detect or drag pin on map.
              <% } %>
            </p>
          </div>

          <button type="submit" class="btn btn-primary" id="saveProfileBtn">
            <i class="fa-solid fa-floppy-disk"></i> Save Profile
          </button>
        </form>
      </div>

      <!-- Aadhaar Upload Card -->
      <div class="profile-form-card">
        <div class="profile-section-title">
          <i class="fa-solid fa-id-card" style="color: var(--accent);"></i> Aadhaar / KYC Document
        </div>

        <% if (currentUser.aadhaarNumber || (currentUser.aadhaarDoc && currentUser.aadhaarDoc.url)) { %>
          <div class="aadhaar-card" style="margin-bottom: 1.5rem;">
            <div style="font-size: 0.75rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.08em;">Government of India</div>
            <div style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.25rem;">Aadhaar</div>
            <div class="aadhaar-number-display">
              <% if (currentUser.aadhaarNumber) { %>
                XXXX XXXX <%= currentUser.aadhaarNumber.slice(-4) %>
              <% } else { %>
                XXXX XXXX XXXX
              <% } %>
            </div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.75rem;">
              <span style="font-size:0.8rem; opacity:0.7;"><%= currentUser.name %></span>
              <% if (currentUser.aadhaarVerified) { %>
                <span class="aadhaar-status-badge verified"><i class="fa-solid fa-circle-check"></i> Verified</span>
              <% } else if (currentUser.aadhaarDoc && currentUser.aadhaarDoc.url) { %>
                <span class="aadhaar-status-badge pending"><i class="fa-solid fa-clock"></i> Pending Review</span>
              <% } else { %>
                <span class="aadhaar-status-badge not-uploaded"><i class="fa-solid fa-circle-exclamation"></i> Not Uploaded</span>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if (!currentUser.aadhaarVerified) { %>
          <form action="/seller/aadhaar" method="POST" enctype="multipart/form-data">
            <div class="form-group">
              <label for="aadhaarNumberKyc">Aadhaar Number</label>
              <input type="text" name="aadhaarNumber" id="aadhaarNumberKyc" class="form-control"
                value="<%= currentUser.aadhaarNumber ? currentUser.aadhaarNumber.replace(/(\d{4})(\d{4})(\d{4})/, '$1 $2 $3') : '' %>"
                placeholder="XXXX XXXX XXXX" maxlength="14"
                oninput="formatAadhaar(this)">
            </div>
            <div class="form-group">
              <label>Upload Aadhaar Card</label>
              <div class="file-upload-area" onclick="document.getElementById('aadhaarUploadFile').click()">
                <input type="file" name="aadhaar" id="aadhaarUploadFile" accept="image/*,application/pdf"
                  onchange="showFileName(this, 'aadhaarUploadLabel')">
                <% if (currentUser.aadhaarDoc && currentUser.aadhaarDoc.url) { %>
                  <div class="file-upload-icon"><i class="fa-solid fa-check-circle" style="color:var(--success);"></i></div>
                  <div class="file-upload-text">Aadhaar uploaded — click to replace</div>
                <% } else { %>
                  <div class="file-upload-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                  <div class="file-upload-text" id="aadhaarUploadLabel">
                    Click to upload front side of Aadhaar card<br>
                    <small style="color:var(--text-hint);">JPG, PNG, or PDF — max 5MB</small>
                  </div>
                <% } %>
              </div>
            </div>
            <button type="submit" class="btn btn-accent">
              <i class="fa-solid fa-upload"></i> Submit Aadhaar
            </button>
          </form>
        <% } else { %>
          <div style="display: flex; align-items: center; gap: 12px; padding: 1rem; background: #dcfce7; border-radius: var(--radius-md); border: 1px solid #86efac;">
            <i class="fa-solid fa-circle-check" style="color: var(--success); font-size: 1.5rem;"></i>
            <div>
              <strong style="color: #166534;">Aadhaar Verified</strong>
              <p style="font-size: 0.85rem; color: #166534; margin: 0;">Your identity has been confirmed by our team.</p>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<script>
  function formatAadhaar(input) {
    let v = input.value.replace(/\D/g, '').substring(0, 12);
    input.value = v.replace(/(\d{4})(?=\d)/g, '$1 ').trim();
  }
  function showFileName(input, targetId) {
    if (input.files && input.files[0]) {
      const el = document.getElementById(targetId);
      if (el) el.innerHTML = '<i class="fa-solid fa-check-circle" style="color:var(--success);"></i> ' + input.files[0].name;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const personalInput = document.getElementById('address');
    const personalSuggestions = document.getElementById('personal-address-suggestions');
    const businessInput = document.getElementById('businessAddress');
    const businessSuggestions = document.getElementById('business-address-suggestions');
    const latInput = document.getElementById('latInput');
    const lngInput = document.getElementById('lngInput');
    const detectLocBtn = document.getElementById('detectLocBtn');
    const gpsStatusText = document.getElementById('gpsStatus');

    // ── Leaflet map setup ──
    const savedLat = parseFloat(latInput.value) || 19.0760;
    const savedLng = parseFloat(lngInput.value) || 72.8777;

    const map = L.map('location-picker-map').setView([savedLat, savedLng], 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a> contributors'
    }).addTo(map);

    const marker = L.marker([savedLat, savedLng], { draggable: true }).addTo(map);

    function updateCoords(lat, lng, label = 'Pin location') {
      latInput.value = lat;
      lngInput.value = lng;
      gpsStatusText.innerHTML = `<i class="fa-solid fa-check-circle" style="color:var(--success);"></i> ${label}: (${lat.toFixed(5)}, ${lng.toFixed(5)}) — <em>Save profile to store it.</em>`;
    }

    // ── Reverse geocode on pin move ──
    async function reverseGeocode(lat, lng, targetInput) {
      try {
        const res = await fetch(
          `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`,
          { headers: { 'Accept-Language': 'en', 'User-Agent': 'RentItApp/1.0' } }
        );
        const data = await res.json();
        if (data && data.display_name && targetInput) {
          targetInput.value = data.display_name;
        }
      } catch (e) { /* silent */ }
    }

    marker.on('dragend', () => {
      const { lat, lng } = marker.getLatLng();
      updateCoords(lat, lng, 'Map pin');
      // Update business address by default when map pin is moved
      reverseGeocode(lat, lng, businessInput);
    });

    map.on('click', (e) => {
      marker.setLatLng(e.latlng);
      updateCoords(e.latlng.lat, e.latlng.lng, 'Map click');
      reverseGeocode(e.latlng.lat, e.latlng.lng, businessInput);
    });

    // ── Autocomplete helper ──
    function setupAutocomplete(inputEl, suggestionsEl) {
      let timer = null;
      inputEl.addEventListener('input', () => {
        clearTimeout(timer);
        const query = inputEl.value.trim();
        if (query.length < 3) {
          suggestionsEl.style.display = 'none';
          return;
        }
        timer = setTimeout(() => {
          fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5&countrycodes=in`, {
            headers: { 'Accept-Language': 'en', 'User-Agent': 'RentItApp/1.0' }
          })
          .then(r => r.json())
          .then(data => {
            suggestionsEl.innerHTML = '';
            if (!data || data.length === 0) {
              suggestionsEl.style.display = 'none';
              return;
            }
            data.forEach(item => {
              const div = document.createElement('div');
              div.style.padding = '8px 10px';
              div.style.cursor = 'pointer';
              div.style.borderBottom = '1px solid var(--border)';
              div.style.fontSize = '0.85rem';
              div.innerHTML = `<i class="fa-solid fa-location-dot" style="color:var(--primary); margin-right:8px;"></i> ${item.display_name}`;
              
              div.addEventListener('mouseover', () => div.style.background = '#f8fafc');
              div.addEventListener('mouseout', () => div.style.background = 'transparent');
              div.addEventListener('click', () => {
                const lat = parseFloat(item.lat);
                const lon = parseFloat(item.lon);
                inputEl.value = item.display_name;
                updateCoords(lat, lon, 'Selected address');
                marker.setLatLng([lat, lon]);
                map.setView([lat, lon], 15);
                suggestionsEl.style.display = 'none';
              });
              suggestionsEl.appendChild(div);
            });
            suggestionsEl.style.display = 'block';
          })
          .catch(() => { suggestionsEl.style.display = 'none'; });
        }, 350);
      });

      document.addEventListener('click', (e) => {
        if (!inputEl.contains(e.target) && !suggestionsEl.contains(e.target)) {
          suggestionsEl.style.display = 'none';
        }
      });
    }

    setupAutocomplete(personalInput, personalSuggestions);
    setupAutocomplete(businessInput, businessSuggestions);

    // ── GPS Detect Button ──
    detectLocBtn.addEventListener('click', () => {
      if (!navigator.geolocation) {
        alert('Geolocation is not supported by your browser.');
        return;
      }
      detectLocBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      detectLocBtn.disabled = true;

      navigator.geolocation.getCurrentPosition(async (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;
        updateCoords(lat, lng, 'Detected GPS');
        marker.setLatLng([lat, lng]);
        map.setView([lat, lng], 15);
        reverseGeocode(lat, lng, businessInput);

        // Also save immediately to DB via AJAX if desired
        await fetch('/seller/location/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lat, lng })
        });

        detectLocBtn.innerHTML = '<i class="fa-solid fa-check"></i> Got it';
        detectLocBtn.disabled = false;
      }, (err) => {
        alert('Could not get your location: ' + err.message);
        detectLocBtn.innerHTML = '<i class="fa-solid fa-crosshairs"></i> Detect';
        detectLocBtn.disabled = false;
      }, { enableHighAccuracy: true });
    });
  });
</script>

<%- include('../layouts/footer') %>

